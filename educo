// Helper Supabase : charge une table avec fallback sur seed
async function sbLoad(table, fallback = []) {
  try {
    const { data, error } = await sb.from(table).select('*');
    if (error) { console.warn('[sb] load', table, error.message); return fallback; }
    return (data && data.length > 0) ? data : fallback;
  } catch(e) { console.warn('[sb] load', table, e); return fallback; }
}
// Helper : upsert un tableau de lignes
async function sbSave(table, rows) {
  if (!rows || rows.length === 0) return;
  try { await sb.from(table).upsert(rows, { onConflict: 'id' }); }
  catch(e) { console.warn('[sb] save', table, e); }
}
// Helper : upsert objet JSON (table kv_store avec colonnes key TEXT, value JSONB, user_id UUID)
async function sbSaveKV(key, value, userId) {
  try { await sb.from('kv_store').upsert({ key: `${userId}:${key}`, value, user_id: userId }, { onConflict: 'key' }); }
  catch(e) { console.warn('[sb] saveKV', key, e); }
}
async function sbLoadKV(key, userId, fallback) {
  try {
    const { data } = await sb.from('kv_store').select('value').eq('key', `${userId}:${key}`).single();
    return data?.value ?? fallback;
  } catch { return fallback; }
}

