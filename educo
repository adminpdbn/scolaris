            {SALLES.map(s=><option key={s}>{s}</option>)}
          </select>
        </div>
        <div className="fg"><label className="fl">Début (h décimal)</label>
          <input className="fi" type="number" step="0.5" min="8" max="20" value={slotForm.debut} onChange={e=>setSlotForm({...slotForm,debut:e.target.value})}/>
          <div style={{fontSize:10,color:'var(--muted)',marginTop:3}}>Ex: 14 = 14h00, 14.5 = 14h30</div>
        </div>
        <div className="fg"><label className="fl">Fin (h décimal)</label>
          <input className="fi" type="number" step="0.5" min="8" max="21" value={slotForm.fin} onChange={e=>setSlotForm({...slotForm,fin:e.target.value})}/>
          <div style={{fontSize:10,color:'var(--muted)',marginTop:3}}>Durée : {slotForm.fin&&slotForm.debut?((parseFloat(slotForm.fin)-parseFloat(slotForm.debut))*60).toFixed(0)+' min':'—'}</div>
        </div>
      </div>
      <div className="fg">
        <label className="fl">Élèves inscrits dans ce groupe</label>
        <div style={{display:'flex',flexWrap:'wrap',gap:6,padding:'8px',border:'1.5px solid var(--cream2)',borderRadius:2,background:'white',maxHeight:120,overflowY:'auto'}}>
          {eleves.map(e=>{const on=slotForm.eleveIds.includes(e.id);return(
            <button key={e.id} onClick={()=>setSlotForm(p=>({...p,eleveIds:on?p.eleveIds.filter(x=>x!==e.id):[...p.eleveIds,e.id]}))}
              style={{padding:'3px 9px',borderRadius:2,border:`1.5px solid ${on?'var(--navy)':'var(--cream2)'}`,background:on?'var(--navy)':'white',color:on?'white':'var(--text)',fontSize:11,fontWeight:on?600:400,cursor:'pointer',fontFamily:'DM Sans,sans-serif'}}>
              {e.name} <span style={{opacity:.6}}>({e.niveau})</span>
            </button>
          );})}
        </div>
      </div>
      {/* Conflict preview */}
      {(()=>{
        const preview={...slotForm,id:editSlot||'__new__',debut:parseFloat(slotForm.debut),fin:parseFloat(slotForm.fin)};
        const others=cours.filter(c=>c.id!==editSlot&&c.jour===preview.jour&&preview.debut<c.fin&&c.debut<preview.fin);
        const pConflicts=[];
        others.forEach(c=>{
          if(c.profId===preview.profId){const p=users.find(u=>u.id===c.profId);pConflicts.push(`⚠️ Prof ${p?.name.split(' ').slice(-1)[0]} déjà sur ${c.matiere} ${c.niveau}`);}
          const shared=preview.eleveIds.filter(id=>c.eleveIds.includes(id));
          shared.forEach(id=>{const e=users.find(u=>u.id===id);pConflicts.push(`⚠️ ${e?.name} déjà inscrit sur ${c.matiere} ${c.niveau}`);});
        });
        return pConflicts.length>0?<div style={{background:'#FFF0F0',border:'1.5px solid var(--err)',borderRadius:2,padding:'9px 12px',marginTop:4}}>
          {pConflicts.map((c,i)=><div key={i} style={{fontSize:12,color:'var(--err)'}}>{c}</div>)}
        </div>:null;
      })()}
      <div className="fa">
        {editSlot&&<button className="btn btn-d" onClick={()=>{deleteSlot(editSlot);setShowSlot(false);}}>🗑️ Supprimer</button>}
        <button className="btn btn-o" onClick={()=>setShowSlot(false)}>Annuler</button>
        <button className="btn btn-p" onClick={saveSlot}>{editSlot?'Enregistrer':'Créer'}</button>
      </div>
    </Modal>}
  </>;
}

