          <div className="sc c-gold"><div className="sc-ic">⏳</div><div className="sc-v">{dispos.filter(d=>d.statut==='reserve').length}</div><div className="sc-l">Réservées</div></div>
          <div className="sc c-navy"><div className="sc-ic">🎉</div><div className="sc-v">{dispos.filter(d=>d.statut==='confirme').length}</div><div className="sc-l">Confirmées</div></div>
