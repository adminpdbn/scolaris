// ─── MES ÉLÈVES + APPEL ───
function MesEleves({user,users,grades,setGrades,cours,appel,setAppel}){
  const [tab,setTab]=useState('notes');
  const eleves=users.filter(u=>u.role==='eleve');
  // Notes tab
  const [sel,setSel]=useState(null);
  const [showNote,setShowNote]=useState(false);
  const [noteForm,setNoteForm]=useState({matiere:'Mathématiques',note:'',max:'20',commentaire:''});
  // Appel tab
  const myCours=cours.filter(c=>c.profId===user.id);

  // ── Détection automatique du créneau en cours ou imminent ──
  const autoSelectCours=(()=>{
    const now=new Date();
    const dayNames=['Dimanche','Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi'];
    const todayName=dayNames[now.getDay()];
    const nowH=now.getHours()+now.getMinutes()/60;
    // 1. Cours en cours maintenant
    const enCours=myCours.find(c=>c.jour===todayName&&c.debut<=nowH&&nowH<=c.fin);
    if(enCours)return{id:enCours.id,label:'En cours'};
    // 2. Prochain cours aujourd'hui (dans les 2h à venir)
    const prochainAujourdhui=myCours
      .filter(c=>c.jour===todayName&&c.debut>nowH&&c.debut-nowH<=2)
      .sort((a,b)=>a.debut-b.debut)[0];
    if(prochainAujourdhui)return{id:prochainAujourdhui.id,label:`Dans ${Math.round((prochainAujourdhui.debut-nowH)*60)} min`};
    // 3. Premier cours du reste de la semaine
    const dayOrder=['Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi','Dimanche'];
    const todayIdx=dayOrder.indexOf(todayName);
    const prochainSemaine=myCours
      .map(c=>({...c,idx:dayOrder.indexOf(c.jour)}))
      .filter(c=>c.idx>todayIdx||(c.idx===todayIdx&&c.debut>nowH))
      .sort((a,b)=>a.idx-b.idx||a.debut-b.debut)[0];
    if(prochainSemaine)return{id:prochainSemaine.id,label:`${prochainSemaine.jour}`};
    // 4. Fallback : premier de la liste
    return myCours[0]?{id:myCours[0].id,label:null}:null;
  })();

  const [selC,setSelC]=useState(autoSelectCours?.id||null);
  const [aDate,setADate]=useState(new Date().toISOString().split('T')[0]);

  const addNote=()=>{
    if(!noteForm.note||!sel)return;
    const g={id:'g'+Date.now(),matiere:noteForm.matiere,note:parseFloat(noteForm.note),max:parseFloat(noteForm.max),date:new Date().toISOString().split('T')[0],commentaire:noteForm.commentaire,profId:user.id};
    setGrades(p=>({...p,[sel]:[...(p[sel]||[]),g]}));
    setShowNote(false);setNoteForm({matiere:'Mathématiques',note:'',max:'20',commentaire:''});
  };

  const aKey=`${selC}|${aDate}`;
  const curAppel=appel[aKey]||{};
  const setStatus=(eid,status)=>setAppel(p=>({...p,[aKey]:{...curAppel,[eid]:status}}));
  const curCours=myCours.find(c=>c.id===selC);
  const coursEleves=curCours?users.filter(u=>curCours.eleveIds.includes(u.id)):[];

  // Historique appels for selected cours
  const histAppel=Object.entries(appel)
    .filter(([k])=>k.startsWith(`${selC}|`)&&k!==aKey)
    .sort(([a],[b])=>b.localeCompare(a)).slice(0,4);

  const statCount=(data,s)=>Object.values(data).filter(x=>x===s).length;

  const selUser=users.find(u=>u.id===sel);
  const selGrades=grades[sel]||[];
  const selMoy=moy(selGrades);

  return <>
    <TB title="Élèves & Appel">
      {tab==='notes'&&sel&&<button className="btn btn-p" onClick={()=>setShowNote(true)}>＋ Note</button>}
    </TB>
    <div className="pg">
      <div className="tabs" style={{maxWidth:380}}>
        <button className={`tab ${tab==='notes'?'on':''}`} onClick={()=>setTab('notes')}>📊 Notes</button>
        <button className={`tab ${tab==='appel'?'on':''}`} onClick={()=>setTab('appel')}>📋 Faire l'appel</button>
      </div>

      {/* ── NOTES TAB ── */}
      {tab==='notes'&&<div style={{display:'grid',gridTemplateColumns:'230px 1fr',gap:18}}>
        <div>
          <div style={{fontFamily:'Playfair Display,serif',fontSize:14,fontWeight:600,marginBottom:9}}>Élèves ({eleves.length})</div>
          <div className="epanel">{eleves.map(e=>{const g=grades[e.id]||[];const mv=moy(g);return<div key={e.id} className={`eitem ${sel===e.id?'on':''}`} onClick={()=>setSel(e.id)}>
            <div><div className="ei-n">{e.name}</div><div className="ei-l">{e.niveau}</div></div>
            {mv&&<span style={{fontWeight:700,fontSize:12,color:sel===e.id?'var(--gold)':gcol(parseFloat(mv),20)}}>{mv}</span>}
          </div>;})}
          </div>
        </div>
        <div>
          {!sel?<div className="emp"><div className="emp-icon">👤</div><h3>Sélectionnez un élève</h3></div>:<>
            <div style={{background:'white',borderRadius:0,padding:'14px 18px',border:'1.5px solid var(--cream2)',marginBottom:16,display:'flex',alignItems:'center',gap:12}}>
              <div style={{width:44,height:44,borderRadius:'50%',background:'var(--navy)',display:'flex',alignItems:'center',justifyContent:'center',fontSize:18}}>🎓</div>
              <div><div style={{fontFamily:'Playfair Display,serif',fontSize:16,fontWeight:600}}>{selUser?.name}</div><div style={{fontSize:12,color:'var(--muted)'}}>{selUser?.niveau} · {selGrades.length} note{selGrades.length!==1?'s':''}</div></div>
              {selMoy&&<div style={{marginLeft:'auto',textAlign:'center'}}><div style={{fontFamily:'Playfair Display,serif',fontSize:24,fontWeight:700,color:gcol(parseFloat(selMoy),20)}}>{selMoy}</div><div style={{fontSize:11,color:'var(--muted)'}}>/ 20</div></div>}
            </div>
            {selGrades.length===0?<div className="emp" style={{padding:'30px 0'}}><div className="emp-icon">📊</div><h3>Aucune note</h3></div>:(
              <table className="tbl">
                <thead><tr><th>Matière</th><th>Note</th><th>Date</th><th>Appréciation</th><th></th></tr></thead>
                <tbody>{selGrades.map(g=><tr key={g.id}>
                  <td><strong>{g.matiere}</strong></td>
                  <td><span style={{fontWeight:700,color:gcol(g.note,g.max)}}>{g.note}/{g.max}</span></td>
                  <td style={{fontSize:12,color:'var(--muted)'}}>{g.date}</td>
                  <td style={{fontSize:12,color:'var(--muted)',fontStyle:'italic'}}>{g.commentaire}</td>
                  <td><button className="btn btn-d btn-sm" onClick={()=>setGrades(p=>({...p,[sel]:p[sel].filter(x=>x.id!==g.id)}))}>🗑️</button></td>
                </tr>)}</tbody>
              </table>
            )}
          </>}
        </div>
      </div>}

      {/* ── APPEL TAB ── */}
      {tab==='appel'&&<>
        {/* Sélecteur cours + date */}
        <div style={{display:'flex',gap:12,marginBottom:20,flexWrap:'wrap',background:'white',padding:'16px',borderRadius:0,border:'1.5px solid var(--cream2)'}}>
          <div className="fg" style={{flex:1,minWidth:220,margin:0}}>
            <label className="fl" style={{display:'flex',alignItems:'center',gap:6}}>
              Cours / créneau
              {autoSelectCours?.label&&<span style={{padding:'1px 7px',borderRadius:0,fontSize:10,fontWeight:700,background:autoSelectCours.label==='En cours'?'#EEFFF6':'#EEF5FF',color:autoSelectCours.label==='En cours'?'var(--ok)':'var(--gold)'}}>{autoSelectCours.label==='En cours'?'🟢 En cours':'🔵 '+autoSelectCours.label}</span>}
            </label>
            <select className="fi" value={selC||''} onChange={e=>setSelC(e.target.value)}>
              {myCours.length===0&&<option value=''>Aucun cours planifié</option>}
              {myCours.map(c=>{
                const dayNames=['Dimanche','Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi'];
                const todayName=dayNames[new Date().getDay()];
                const nowH=new Date().getHours()+new Date().getMinutes()/60;
                const isNow=c.jour===todayName&&c.debut<=nowH&&nowH<=c.fin;
                const isSoon=c.jour===todayName&&c.debut>nowH&&c.debut-nowH<=2;
                return <option key={c.id} value={c.id}>{isNow?'🟢 ':isSoon?'🔵 ':''}{c.matiere} — {c.niveau} · {c.jour} {hs(c.debut)}–{hs(c.fin)}</option>;
              })}
            </select>
          </div>
          <div className="fg" style={{margin:0}}>
            <label className="fl">Date de la séance</label>
            <input type="date" className="fi" value={aDate} onChange={e=>setADate(e.target.value)}/>
          </div>
          {curCours&&<div style={{alignSelf:'flex-end',paddingBottom:0}}>
            <span style={{...getCoursBadge(curCours.matiere),fontSize:12}}>{curCours.salle}</span>
          </div>}
        </div>

        {!selC||coursEleves.length===0?
          <div className="emp"><div className="emp-icon">📋</div><h3>Sélectionnez un cours</h3><p>Choisissez un cours pour faire l'appel.</p></div>
        :<>
          <div style={{background:'white',borderRadius:0,border:'1.5px solid var(--cream2)',overflow:'hidden',marginBottom:20}}>
            {/* Header */}
            <div style={{padding:'11px 16px',borderBottom:'1px solid var(--cream2)',display:'flex',justifyContent:'space-between',alignItems:'center',background:'var(--cream)'}}>
              <div style={{fontWeight:600,fontSize:14}}>{curCours.matiere} — {curCours.niveau}</div>
              <div style={{display:'flex',gap:14,fontSize:12}}>
                <span style={{color:'var(--ok)',fontWeight:600}}>✓ {statCount(curAppel,'present')}</span>
                <span style={{color:'#D97706',fontWeight:600}}>⏰ {statCount(curAppel,'retard')}</span>
                <span style={{color:'var(--err)',fontWeight:600}}>✗ {statCount(curAppel,'absent')}</span>
                <span style={{color:'var(--muted)'}}>— {coursEleves.length-Object.keys(curAppel).length} non renseigné{coursEleves.length-Object.keys(curAppel).length>1?'s':''}</span>
              </div>
            </div>
            {/* Élève rows */}
            {coursEleves.map(e=>{
              const status=curAppel[e.id];
              return <div key={e.id} className="appel-row">
                <div style={{display:'flex',alignItems:'center',gap:11}}>
                  <div style={{width:38,height:38,borderRadius:2,background:status==='present'?'#EEFFF6':status==='absent'?'#FFF0F0':status==='retard'?'#FFF8EE':'var(--cream2)',display:'flex',alignItems:'center',justifyContent:'center',fontSize:16,border:`2px solid ${status==='present'?'var(--ok)':status==='absent'?'var(--err)':status==='retard'?'#D97706':'transparent'}`,transition:'all .2s'}}>🎓</div>
                  <div>
                    <div style={{fontWeight:600,fontSize:14}}>{e.name}</div>
                    <div style={{fontSize:11,color:'var(--muted)'}}>{e.niveau}</div>
                  </div>
                </div>
                <div style={{display:'flex',gap:7}}>
                  {[
                    {s:'present',icon:'✓',label:'Présent',bg:'#EEFFF6',col:'var(--ok)'},
                    {s:'retard',icon:'⏰',label:'Retard',bg:'#FFF8EE',col:'#D97706'},
                    {s:'absent',icon:'✗',label:'Absent',bg:'#FFF0F0',col:'var(--err)'},
                  ].map(({s,icon,label,bg,col})=>(
                    <button key={s} className="appel-stat-btn" onClick={()=>setStatus(e.id,s)}
                      style={{background:status===s?bg:'white',color:status===s?col:'var(--muted)',borderColor:status===s?col:'var(--cream2)',fontWeight:status===s?700:400}}>
                      {icon} {label}
                    </button>
                  ))}
                </div>
              </div>;
            })}
            <div className="appel-footer">
              <span style={{color:'var(--muted)'}}>💾 Sauvegarde automatique</span>
            </div>
          </div>

          {/* Historique */}
          {histAppel.length>0&&<>
            <div className="sh"><h2 className="st" style={{fontSize:16}}>Séances précédentes</h2></div>
            <table className="tbl">
              <thead><tr><th>Date</th><th>Présents</th><th>Retards</th><th>Absents</th></tr></thead>
              <tbody>{histAppel.map(([k,data])=>{
                const date=k.split('|')[1];
                return <tr key={k}>
                  <td style={{fontWeight:500}}>{date}</td>
                  <td><span style={{color:'var(--ok)',fontWeight:600}}>{statCount(data,'present')}/{coursEleves.length}</span></td>
                  <td><span style={{color:'#D97706',fontWeight:600}}>{statCount(data,'retard')}</span></td>
                  <td><span style={{color:'var(--err)',fontWeight:600}}>{statCount(data,'absent')}</span></td>
                </tr>;
              })}</tbody>
            </table>
          </>}
        </>}
      </>}
    </div>
    {showNote&&<Modal title="Ajouter une note" onClose={()=>setShowNote(false)}>
      <div className="fg"><label className="fl">Matière</label><select className="fi" value={noteForm.matiere} onChange={e=>setNoteForm({...noteForm,matiere:e.target.value})}>{MATIERES.filter(m=>m!=='Toutes').map(m=><option key={m}>{m}</option>)}</select></div>
      <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:10}}>
        <div className="fg"><label className="fl">Note *</label><input className="fi" type="number" min="0" max="20" step="0.5" value={noteForm.note} onChange={e=>setNoteForm({...noteForm,note:e.target.value})} placeholder="Ex: 14"/></div>
        <div className="fg"><label className="fl">/ Barème</label><input className="fi" type="number" value={noteForm.max} onChange={e=>setNoteForm({...noteForm,max:e.target.value})}/></div>
      </div>
      <div className="fg"><label className="fl">Appréciation</label><textarea className="fi" value={noteForm.commentaire} onChange={e=>setNoteForm({...noteForm,commentaire:e.target.value})} placeholder="Commentaire..."/></div>
      <div className="fa"><button className="btn btn-o" onClick={()=>setShowNote(false)}>Annuler</button><button className="btn btn-p" onClick={addNote}>Enregistrer</button></div>
    </Modal>}
  </>;
}

// ─── MODULES (admin crée, tous consultent) ───
function Modules({user,users,modules,setModules,enrollments,setEnrollments}){
  const [fm,setFm]=useState('Toutes');
  const [show,setShow]=useState(false);
  const [form,setForm]=useState({title:'',emoji:'📚',desc:'',niveau:'3ème',date:'',heure:'',places:10,lieu:'Salle A',matiere:'Mathématiques',bg:'#EEF3FF',profId:'p1'});
  const isAdmin=user.role==='admin';
  const myEnr=enrollments[user.id]||[];
  const filtered=fm==='Toutes'?modules:modules.filter(m=>m.matiere===fm);
  const isEnr=(id)=>myEnr.includes(id);
  const allProfs=users.filter(u=>u.role==='prof');

  const enroll=(id)=>{const mod=modules.find(m=>m.id===id);if(!mod||mod.inscrits>=mod.places)return;setEnrollments(p=>({...p,[user.id]:[...(p[user.id]||[]),id]}));setModules(p=>p.map(m=>m.id===id?{...m,inscrits:m.inscrits+1}:m));};
  const unenroll=(id)=>{setEnrollments(p=>({...p,[user.id]:(p[user.id]||[]).filter(x=>x!==id)}));setModules(p=>p.map(m=>m.id===id?{...m,inscrits:Math.max(0,m.inscrits-1)}:m));};
  const add=()=>{if(!form.title.trim())return;setModules(p=>[...p,{id:'m'+Date.now(),...form,places:parseInt(form.places),inscrits:0}]);setShow(false);};
  const del=(id)=>{setModules(p=>p.filter(m=>m.id!==id));setEnrollments(p=>{const n={...p};Object.keys(n).forEach(k=>{n[k]=(n[k]||[]).filter(x=>x!==id)});return n;});};

  return <>
    <TB title="Modules & Activités">
      {isAdmin&&<button className="btn btn-p" onClick={()=>setShow(true)}>＋ Créer un module</button>}
    </TB>
    <div className="pg">
      {!isAdmin&&<div style={{background:'#EEF5FF',border:'1.5px solid rgba(26,111,212,.3)',borderRadius:0,padding:'9px 14px',marginBottom:16,fontSize:13,color:'#0d4a8f'}}>
        📋 Les modules sont créés et gérés par l'administration. Contactez l'admin pour toute demande d'ajout.
      </div>}
      <div className="fb">
        <span style={{fontSize:11,fontWeight:600,color:'var(--muted)',alignSelf:'center',marginRight:3}}>Matière :</span>
        {MATIERES.map(m=><button key={m} className={`chip ${fm===m?'on':''}`} onClick={()=>setFm(m)}>{m}</button>)}
      </div>
      {filtered.length===0?<div className="emp"><div className="emp-icon">🗓️</div><h3>Aucun module</h3></div>:(
        <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fill,minmax(268px,1fr))',gap:16}}>
          {filtered.map(mod=>{
            const enrolled=isEnr(mod.id);
            const full=mod.inscrits>=mod.places;
            const pct=Math.min((mod.inscrits/mod.places)*100,100);
            const prof=users.find(u=>u.id===mod.profId);
            return <div key={mod.id} className="mc">
              <div className="mc-hd" style={{background:mod.bg||'#EEF3FF'}}>
                <span>{mod.emoji}</span>
                {enrolled&&<span style={{position:'absolute',top:8,right:8,background:'var(--info)',color:'white',fontSize:10,fontWeight:700,padding:'2px 7px',borderRadius:2}}>✓ Inscrit</span>}
                {full&&!enrolled&&<span style={{position:'absolute',top:8,right:8,background:'var(--err)',color:'white',fontSize:10,fontWeight:700,padding:'2px 7px',borderRadius:2}}>Complet</span>}
              </div>
              <div className="mc-bd">
                <div className="mc-ttl">{mod.title}</div>
                <div className="mc-inf">
                  <div>📅 {mod.date} · {mod.heure}</div>
                  <div>📍 {mod.lieu} · 🎯 {mod.niveau}</div>
                  {prof&&<div>👤 {prof.name.split(' ').slice(-1)[0]}</div>}
                </div>
                <p style={{fontSize:12,color:'var(--muted)',margin:'0 0 11px',lineHeight:1.5}}>{mod.desc}</p>
                <div style={{marginBottom:11}}>
                  <div style={{display:'flex',justifyContent:'space-between',fontSize:11,color:'var(--muted)',marginBottom:3}}><span>Places</span><span style={{fontWeight:600}}>{mod.inscrits}/{mod.places}</span></div>
                  <div className="pb"><div className="pbf" style={{width:`${pct}%`,background:pct>=100?'var(--err)':pct>70?'#D97706':'var(--ok)'}}/></div>
                </div>
                <div style={{display:'flex',gap:7}}>
                  {user.role==='eleve'&&(enrolled?
                    <button className="btn btn-o" style={{flex:1,fontSize:12}} onClick={()=>unenroll(mod.id)}>Se désinscrire</button>:
                    <button className="btn btn-p" style={{flex:1,fontSize:12}} disabled={full} onClick={()=>enroll(mod.id)}>{full?'Complet':"S'inscrire"}</button>
                  )}
                  {isAdmin&&<button className="btn btn-d btn-sm" onClick={()=>del(mod.id)}>🗑️</button>}
                </div>
              </div>
            </div>;
          })}
        </div>
      )}
    </div>
    {show&&<Modal title="Créer un module" onClose={()=>setShow(false)}>
      <div style={{display:'grid',gridTemplateColumns:'1fr 70px',gap:10}}>
        <div className="fg"><label className="fl">Titre *</label><input className="fi" value={form.title} onChange={e=>setForm({...form,title:e.target.value})} placeholder="Ex: Stage Maths Brevet"/></div>
        <div className="fg"><label className="fl">Emoji</label><input className="fi" value={form.emoji} onChange={e=>setForm({...form,emoji:e.target.value})} style={{textAlign:'center',fontSize:18}}/></div>
      </div>
      <div className="fg"><label className="fl">Professeur responsable</label>
        <select className="fi" value={form.profId} onChange={e=>setForm({...form,profId:e.target.value})}>
          {allProfs.map(p=><option key={p.id} value={p.id}>{p.name}</option>)}
        </select>
      </div>
      <div className="fg"><label className="fl">Description</label><textarea className="fi" value={form.desc} onChange={e=>setForm({...form,desc:e.target.value})}/></div>
      <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:10}}>
        <div className="fg"><label className="fl">Date</label><input className="fi" type="date" value={form.date} onChange={e=>setForm({...form,date:e.target.value})}/></div>
        <div className="fg"><label className="fl">Horaires</label><input className="fi" value={form.heure} onChange={e=>setForm({...form,heure:e.target.value})} placeholder="14h00–17h00"/></div>
        <div className="fg"><label className="fl">Places</label><input className="fi" type="number" value={form.places} onChange={e=>setForm({...form,places:e.target.value})}/></div>
        <div className="fg"><label className="fl">Lieu</label><input className="fi" value={form.lieu} onChange={e=>setForm({...form,lieu:e.target.value})}/></div>
        <div className="fg"><label className="fl">Niveau</label><select className="fi" value={form.niveau} onChange={e=>setForm({...form,niveau:e.target.value})}>{NIVEAUX.filter(n=>n!=='Tous').map(n=><option key={n}>{n}</option>)}</select></div>
        <div className="fg"><label className="fl">Matière</label><select className="fi" value={form.matiere} onChange={e=>setForm({...form,matiere:e.target.value})}>{MATIERES.filter(m=>m!=='Toutes').map(m=><option key={m}>{m}</option>)}</select></div>
      </div>
      <div className="fa"><button className="btn btn-o" onClick={()=>setShow(false)}>Annuler</button><button className="btn btn-p" onClick={add}>Créer</button></div>
    </Modal>}
  </>;
}

// ─── ADMIN ───
// ─── PLANNING EDITOR ───
function PlanningEditor({users,cours,setCours}){
  const [showSlot,setShowSlot]=useState(false);
  const [editSlot,setEditSlot]=useState(null);
  const [slotForm,setSlotForm]=useState({profId:'',matiere:'Mathématiques',niveau:'3ème',jour:'Lundi',debut:'14',fin:'15.5',salle:'Salle A',eleveIds:[]});
  const SALLES=['Salle A','Salle B','Salle C','Salle D'];
  const PH=42;
  const PH_START=9,PH_END=20;
  const PHOURS=Array.from({length:PH_END-PH_START+1},(_,i)=>i+PH_START);
  const [dragId,setDragId]=useState(null);
  const [dragOver,setDragOver]=useState(null);
  const dragRef=React.useRef({offsetH:0});
  const eleves=users.filter(u=>u.role==='eleve');
  const profs=users.filter(u=>u.role==='prof');

  const overlapLayout=useMemo(()=>{
    const map={};
    DAYS.forEach(jour=>{
      const slots=cours.filter(c=>c.jour===jour).sort((a,b)=>a.debut-b.debut);
      const colEnd=[];
      slots.forEach(s=>{
        let col=colEnd.findIndex(end=>end<=s.debut);
        if(col===-1){col=colEnd.length;}
        colEnd[col]=s.fin;
        map[s.id]={col};
      });
      slots.forEach(s=>{
        const ov=slots.filter(o=>o.debut<s.fin&&o.fin>s.debut);
        map[s.id].total=Math.max(...ov.map(o=>map[o.id]?.col??0))+1;
      });
      slots.forEach(s=>{
        const ov=slots.filter(o=>o.debut<s.fin&&o.fin>s.debut);
        const maxT=Math.max(...ov.map(o=>map[o.id].total));
        ov.forEach(o=>{map[o.id].total=maxT;});
      });
    });
    return map;
  },[cours]);

  const conflicts=useMemo(()=>{
    const list=[];
    cours.forEach((c,i)=>{
      cours.slice(i+1).forEach(c2=>{
        if(c.jour!==c2.jour)return;
        const overlap=c.debut<c2.fin&&c2.debut<c.fin;
        if(!overlap)return;
        if(c.profId===c2.profId){
          const p=users.find(u=>u.id===c.profId);
          list.push({type:'prof',ids:[c.id,c2.id],msg:`👨‍🏫 ${p?.name.split(' ').slice(-1)[0]} est dans 2 créneaux simultanés (${c.matiere} & ${c2.matiere}) le ${c.jour} ${hs(c.debut)}–${hs(c.fin)}`});
        }
        const shared=c.eleveIds.filter(id=>c2.eleveIds.includes(id));
        shared.forEach(eid=>{
          const e=users.find(u=>u.id===eid);
          list.push({type:'eleve',ids:[c.id,c2.id],msg:`🎓 ${e?.name} est dans 2 créneaux simultanés (${c.matiere} & ${c2.matiere}) le ${c.jour} ${hs(c.debut)}–${hs(c.fin)}`});
        });
      });
    });
    return list;
  },[cours,users]);
  const conflictIds=new Set(conflicts.flatMap(c=>c.ids));

  const openNewSlot=(jour,debut)=>{
    setEditSlot(null);
    setSlotForm({profId:profs[0]?.id||'',matiere:'Mathématiques',niveau:'3ème',jour:jour||'Lundi',debut:String(debut||14),fin:String((debut||14)+1.5),salle:'Salle A',eleveIds:[]});
    setShowSlot(true);
  };
  const openEditSlot=(c)=>{
    setEditSlot(c.id);
    setSlotForm({profId:c.profId,matiere:c.matiere,niveau:c.niveau,jour:c.jour,debut:String(c.debut),fin:String(c.fin),salle:c.salle,eleveIds:[...c.eleveIds]});
    setShowSlot(true);
  };
  const saveSlot=()=>{
    const s={...slotForm,debut:parseFloat(slotForm.debut),fin:parseFloat(slotForm.fin)};
    if(!s.profId||s.debut>=s.fin)return;
    if(editSlot){setCours(p=>p.map(c=>c.id===editSlot?{...c,...s}:c));}
    else{setCours(p=>[...p,{id:'c'+Date.now(),...s}]);}
    setShowSlot(false);
  };
  const deleteSlot=(id)=>{if(window.confirm('Supprimer ce créneau ?'))setCours(p=>p.filter(c=>c.id!==id));};

  return <>
    <div style={{marginTop:8}}>
        {/* Conflicts banner */}
        {conflicts.length>0&&<div className="conflict-panel">
          <div style={{fontWeight:700,fontSize:13,color:'var(--err)',marginBottom:8}}>⚠️ {conflicts.length} conflit{conflicts.length>1?'s':''} détecté{conflicts.length>1?'s':''}</div>
          {conflicts.map((c,i)=><div key={i} className="conflict-item">→ {c.msg}</div>)}
        </div>}
        <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:14}}>
          <div style={{fontSize:12,color:'var(--muted)'}}>🖱️ Glisser pour déplacer · Cliquer pour modifier · Cellule vide pour créer</div>
          <button className="btn btn-p btn-sm" onClick={()=>openNewSlot('Lundi',14)}>＋ Nouveau créneau</button>
        </div>
        {/* Planning grid */}
        <div style={{overflowX:'auto',userSelect:'none'}}>
        <div className="plan-grid" style={{minWidth:700}}>
          {/* Header */}
          <div className="plan-hd"/>
          {DAYS.map(d=><div key={d} className="plan-hd">{d.slice(0,3).toUpperCase()}</div>)}
          {/* Body */}
          {PHOURS.map(h=><React.Fragment key={h}>
            <div className="plan-time-lbl" style={{height:PH}}>{h}h</div>
            {DAYS.map(d=>{
              const isOver=dragOver&&dragOver.jour===d&&dragOver.h===h;
              // Preview slot while dragging
              const draggedC=dragId?cours.find(c=>c.id===dragId):null;
              const previewTop=0;
              const previewH=draggedC?(draggedC.fin-draggedC.debut)*PH-2:0;
              return <div key={d}
                className={`plan-day-col plan-cell${isOver?' drop-target':''}`}
                style={{height:PH,position:'relative'}}
                onDragOver={e=>{e.preventDefault();setDragOver({jour:d,h});}}
                onDragLeave={()=>setDragOver(null)}
                onDrop={e=>{
                  e.preventDefault();
                  if(!dragId||!dragOver)return;
                  const c=cours.find(x=>x.id===dragId);
                  if(!c)return;
                  const dur=c.fin-c.debut;
                  // Snap to .5h increments
                  const newDebut=Math.round((dragOver.h+dragRef.current.offsetH)*2)/2;
                  const clamped=Math.max(PH_START,Math.min(PH_END-dur,newDebut));
                  setCours(p=>p.map(x=>x.id===dragId?{...x,jour:dragOver.jour,debut:clamped,fin:Math.round((clamped+dur)*2)/2}:x));
                  setDragId(null);setDragOver(null);
                }}
                onClick={e=>{if(e.target===e.currentTarget&&!dragId)openNewSlot(d,h);}}>
                {/* Drop preview ghost */}
                {isOver&&draggedC&&<div className="drop-preview" style={{top:previewTop,height:previewH}}/>}
                {/* Slots starting this hour */}
                {cours.filter(c=>c.jour===d&&c.debut>=h&&c.debut<h+1).map(c=>{
                  const clr=mc(c.matiere);
                  const top=(c.debut-h)*PH;
                  const height=(c.fin-c.debut)*PH-2;
                  const hasConflict=conflictIds.has(c.id);
                  const p=users.find(u=>u.id===c.profId);
                  const isDragging=dragId===c.id;
                  return <div key={c.id}
                    className={`plan-slot${hasConflict?' conflict':''}${isDragging?' dragging':''}`}
                    draggable
                    style={(()=>{
                      const ol=overlapLayout[c.id]||{col:0,total:1};
                      const gap=2;
                      const pct=100/ol.total;
                      return {
                        top,height,
                        background:clr.bg,
                        borderColor:hasConflict?'var(--err)':clr.bd,
                        position:'absolute',
                        left:`calc(${ol.col*pct}% + ${gap}px)`,
                        width:`calc(${pct}% - ${gap*2}px)`,
                        right:'auto',
                        zIndex:isDragging?10:2
                      };
                    })()}
                    onDragStart={e=>{
                      // Calculate where in the slot the user grabbed
                      const rect=e.currentTarget.getBoundingClientRect();
                      const offsetPx=e.clientY-rect.top;
                      dragRef.current.offsetH=-(offsetPx/PH);
                      setDragId(c.id);
                      e.dataTransfer.effectAllowed='move';
                      // Transparent drag image
                      const ghost=document.createElement('div');
                      ghost.style.cssText='position:fixed;top:-1000px;width:80px;height:40px;background:transparent';
                      document.body.appendChild(ghost);
                      e.dataTransfer.setDragImage(ghost,0,0);
                      setTimeout(()=>document.body.removeChild(ghost),0);
                    }}
                    onDragEnd={()=>{setDragId(null);setDragOver(null);}}
                    onClick={e=>{e.stopPropagation();if(!dragId)openEditSlot(c);}}>
                    {hasConflict&&<span className="conflict-badge">⚠️</span>}
                    <div style={{fontSize:10,fontWeight:700,color:clr.tx,lineHeight:1.2}}>{c.matiere}</div>
                    {height>28&&<div style={{fontSize:9,color:'var(--text)',opacity:.8}}>{c.niveau}</div>}
                    {height>42&&<div style={{fontSize:9,color:'var(--muted)'}}>{hs(c.debut)}–{hs(c.fin)}</div>}
                    {height>56&&<div style={{fontSize:9,color:'var(--muted)'}}>{p?.name.split(' ').slice(-1)[0]}</div>}
                    <div style={{position:'absolute',bottom:2,right:3,fontSize:9,opacity:.4}}>⠿</div>
                  </div>;
                })}
              </div>;
            })}
          </React.Fragment>)}
        </div>
        </div>
        {/* Legend */}
        <div style={{display:'flex',gap:16,flexWrap:'wrap',marginTop:12,fontSize:12,color:'var(--muted)'}}>
          {Object.entries(MC).map(([m,c])=><span key={m} style={{display:'flex',alignItems:'center',gap:4}}><span style={{width:10,height:10,borderRadius:2,background:c.bg,border:`2px solid ${c.bd}`,display:'inline-block'}}/>{m}</span>)}
          <span style={{display:'flex',alignItems:'center',gap:4,color:'var(--err)'}}><span style={{width:10,height:10,borderRadius:2,background:'#FFF0F0',border:'2px solid var(--err)',display:'inline-block'}}/>Conflit</span>
        </div>

    </div>
    {showSlot&&<Modal title={editSlot?'Modifier le créneau':'Nouveau créneau'} onClose={()=>setShowSlot(false)}>
      <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:10}}>
        <div className="fg" style={{gridColumn:'1/-1'}}><label className="fl">Professeur *</label>
          <select className="fi" value={slotForm.profId} onChange={e=>setSlotForm({...slotForm,profId:e.target.value})}>
            <option value="">— Sélectionner —</option>
            {profs.map(p=><option key={p.id} value={p.id}>{p.name}</option>)}
          </select>
        </div>
        <div className="fg"><label className="fl">Matière</label>
          <select className="fi" value={slotForm.matiere} onChange={e=>setSlotForm({...slotForm,matiere:e.target.value})}>
            {MATIERES.filter(m=>m!=='Toutes').map(m=><option key={m}>{m}</option>)}
          </select>
