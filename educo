          onDrop={e=>{e.preventDefault();e.currentTarget.classList.remove('drag');const f=e.dataTransfer.files[0];if(f)handleGNFile(f);}}
          onClick={()=>document.getElementById('gn-input').click()}>
          <input id="gn-input" type="file" accept=".pdf,image/*" onChange={e=>handleGNFile(e.target.files[0])}/>
          {gnPreview&&gnPreview.type==='image'?<img src={gnPreview.src} className="preview-thumb" alt="preview"/>:<div className="gn-icon">{gnFile?'📄':'📂'}</div>}
          {gnFile
            ?<div><div style={{fontWeight:600,fontSize:13}}>{gnFile.name}</div><div style={{fontSize:11,color:'var(--muted)',marginTop:3}}>{(gnFile.size/1024).toFixed(0)} Ko</div></div>
            :<div><div style={{fontWeight:600,fontSize:13}}>Glisser-déposer ou cliquer</div><div style={{fontSize:11,color:'var(--muted)',marginTop:3}}>PDF ou image — export GoodNotes</div></div>
          }
        </div>
        {gnError&&<div style={{color:'var(--err)',fontSize:12,marginTop:8,padding:'8px 12px',background:'#FFF0F0',borderRadius:2}}>{gnError}</div>}
        <div style={{background:'#EEF5FF',borderRadius:2,padding:'9px 12px',fontSize:12,color:'#0d4a8f',marginTop:12}}>
          💡 <strong>Export GoodNotes :</strong> Ouvrez votre note → ••• → Exporter → PDF ou Image
        </div>
        <div className="fa"><button className="btn btn-o" onClick={()=>setShowGN(false)}>Annuler</button><button className="btn btn-p" disabled={!gnFile} onClick={analyzeWithClaude}>🔍 Analyser avec Claude</button></div>
