// ─── MON PROGRAMME (Élève : fusion Suivi + Bibliothèque) ───
function MonProgramme({user,users,cours,resources,compEtats,setCompEtats,customComps=[]}){
  const [selMat,setSelMat]=useState('Toutes');
  const [expandedChaps,setExpandedChaps]=useState({});
  const toggleChap=(key)=>setExpandedChaps(p=>({...p,[key]:!p[key]}));

  const myCours=cours.filter(c=>c.eleveIds.includes(user.id));
  const myMats=new Set(myCours.map(c=>c.matiere));

  // All templates for this student
  const myTemplates=[
    ...COMP_TEMPLATES.filter(t=>myMats.has(t.matiere)&&t.niveau===user.niveau),
    ...(customComps||[]).filter(t=>t.eleveId===user.id),
  ];

  // Resources filtered by student's matières
  const myResources=resources.filter(r=>myMats.has(r.matiere)||r.matiere==='Multi');

  const getEtat=(tid)=>(compEtats[user.id]||{})[tid]||{statut:'non_commence'};
  const requestWork=(tid)=>setCompEtats(p=>({...p,[user.id]:{...(p[user.id]||{}),[tid]:{...getEtat(tid),statut:'en_cours',date:new Date().toISOString().split('T')[0]}}}));

  const mats=['Toutes',...Array.from(myMats)];
  const visibleTemplates=selMat==='Toutes'?myTemplates:myTemplates.filter(t=>t.matiere===selMat);
  const visibleResources=selMat==='Toutes'?myResources:myResources.filter(r=>r.matiere===selMat||r.matiere==='Multi');

  // Stats
  const valide=myTemplates.filter(t=>getEtat(t.id).statut==='valide').length;
  const pct=myTemplates.length?Math.round((valide/myTemplates.length)*100):0;

  // Group competences by matière > chapitre
  const grouped={};
  visibleTemplates.forEach(t=>{
    if(!grouped[t.matiere])grouped[t.matiere]={};
    if(!grouped[t.matiere][t.chapitre])grouped[t.matiere][t.chapitre]=[];
    grouped[t.matiere][t.chapitre].push({...t,etat:getEtat(t.id)});
  });

  const StatDot=({st})=>{
    const s=COMP_STATUTS[st]||COMP_STATUTS.non_commence;
    return <span title={s.label} style={{width:18,height:18,borderRadius:2,background:s.bg,border:`2px solid ${s.color}60`,display:'inline-flex',alignItems:'center',justifyContent:'center',fontSize:10,color:s.color,fontWeight:700,flexShrink:0}}>{s.icon}</span>;
  };

  return <>
    <TB title="Mon Programme"/>
    <div className="pg">
      {/* Welcome + global progress */}
      <div style={{background:'linear-gradient(135deg,var(--navy) 0%,#1A4080 100%)',borderRadius:0,padding:'20px 24px',marginBottom:20,color:'white'}}>
        <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',gap:16}}>
          <div>
            <div style={{fontFamily:'Cormorant Garamond,serif',fontSize:22,fontWeight:600}}>{user.name.split(' ')[0]} — {user.niveau}</div>
            <div style={{fontSize:13,opacity:.7,marginTop:4}}>{Array.from(myMats).join(' · ')} · {myTemplates.length} compétences</div>
          </div>
          <div style={{textAlign:'center',flexShrink:0}}>
            <div style={{fontFamily:'Cormorant Garamond,serif',fontSize:36,fontWeight:600,lineHeight:1}}>{pct}%</div>
            <div style={{fontSize:11,opacity:.6,marginTop:2}}>{valide}/{myTemplates.length} validées</div>
          </div>
        </div>
        <div style={{height:6,background:'rgba(255,255,255,.15)',borderRadius:3,marginTop:16,overflow:'hidden'}}>
          <div style={{height:'100%',width:`${pct}%`,background:pct===100?'#10B981':'#8b6b3a',borderRadius:3,transition:'width .8s'}}/>
        </div>
      </div>

      {/* Matière tabs */}
      <div className="tabs" style={{marginBottom:20,flexWrap:'wrap'}}>
        {mats.map(m=><button key={m} className={`tab ${selMat===m?'on':''}`} onClick={()=>setSelMat(m)} style={{fontSize:12}}>{m}</button>)}
      </div>

      {myMats.size===0&&<div className="emp"><div className="emp-icon">📖</div><h3>Aucun cours inscrit</h3><p>Demandez à votre administrateur de vous inscrire à des cours.</p></div>}

      {/* Matières > Chapitres */}
      {Object.entries(grouped).map(([mat,chaps])=>(
        <div key={mat} style={{marginBottom:24}}>
          <div style={{display:'flex',alignItems:'center',gap:8,marginBottom:12}}>
            <span style={{...getCoursBadge(mat),fontSize:13}}>{mat}</span>
            {(()=>{const all=Object.values(chaps).flat();const v=all.filter(c=>c.etat.statut==='valide').length;return<span style={{fontSize:12,color:'var(--muted)'}}>{v}/{all.length}</span>})()}
          </div>
          {Object.entries(chaps).map(([chap,comps])=>{
            const chapKey=mat+'__'+chap;
            const isOpen=expandedChaps[chapKey]!==false; // open by default
            const chapV=comps.filter(c=>c.etat.statut==='valide').length;
            const chapPct=Math.round((chapV/comps.length)*100);
            // Resources matching this chapter (by matière)
            const chapRes=myResources.filter(r=>r.matiere===mat&&(r.chapitre===chap||!r.chapitre));
            return <div key={chap} style={{background:'white',border:'1.5px solid var(--cream2)',borderRadius:0,marginBottom:10,overflow:'hidden'}}>
              {/* Chapter header — clickable */}
              <div onClick={()=>toggleChap(chapKey)} style={{padding:'12px 16px',background:chapPct===100?'#ECFDF5':'var(--cream)',display:'flex',alignItems:'center',gap:12,cursor:'pointer',userSelect:'none'}}>
                <span style={{fontSize:13,opacity:.5,transition:'transform .2s',transform:isOpen?'rotate(90deg)':'rotate(0deg)'}}>▶</span>
                <div style={{flex:1}}>
                  <div style={{fontWeight:700,fontSize:13,color:'var(--navy)'}}>{chap}</div>
                  <div style={{fontSize:11,color:'var(--muted)',marginTop:1}}>{chapV}/{comps.length} validée{chapV>1?'s':''}{chapRes.length>0?` · ${chapRes.length} ressource${chapRes.length>1?'s':''}`:''}
                  </div>
                </div>
                <div style={{width:80}}>
                  <div style={{height:5,background:'var(--cream2)',borderRadius:3,overflow:'hidden'}}>
                    <div style={{height:'100%',width:`${chapPct}%`,background:chapPct===100?'var(--ok)':'var(--gold)',borderRadius:3}}/>
                  </div>
                  <div style={{fontSize:10,textAlign:'right',color:'var(--muted)',marginTop:2}}>{chapPct}%</div>
                </div>
                {chapPct===100&&<span style={{fontSize:18}}>🏆</span>}
              </div>

              {isOpen&&<div>
                {/* Competences */}
                {comps.map(c=>{
                  const st=COMP_STATUTS[c.etat.statut]||COMP_STATUTS.non_commence;
                  return <div key={c.id} style={{display:'flex',alignItems:'center',gap:10,padding:'8px 16px',borderBottom:'1px solid rgba(0,0,0,.035)'}}>
                    <StatDot st={c.etat.statut}/>
                    <div style={{flex:1,minWidth:0}}>
                      <span style={{fontSize:13,fontWeight:500}}>{c.nom}</span>
                      {c.etat.commentaire&&<div style={{fontSize:11,color:'var(--muted)',fontStyle:'italic',marginTop:2}}>💬 {c.etat.commentaire}</div>}
                    </div>
                    {c.etat.statut==='non_commence'&&<button className="btn btn-sm" style={{fontSize:11,padding:'3px 9px',background:'#FFF8EE',border:'1.5px solid #F0C080',color:'#D97706',flexShrink:0}} onClick={()=>requestWork(c.id)}>Je travaille ça</button>}
                    {c.etat.statut==='valide'&&<span style={{fontSize:11,color:'var(--ok)',fontWeight:600,flexShrink:0}}>✓ Validé</span>}
                    {c.etat.statut==='a_revoir'&&<span style={{fontSize:11,color:'var(--err)',fontWeight:600,flexShrink:0}}>↺ À revoir</span>}
                    {c.etat.statut==='en_cours'&&<span style={{fontSize:11,color:'#D97706',fontWeight:600,flexShrink:0}}>◑ En cours</span>}
                  </div>;
                })}

                {/* Inline resources for this chapter */}
                {chapRes.length>0&&<div style={{padding:'10px 16px',background:'#F7FAFF',borderTop:'1px solid #E8F0FE'}}>
                  <div style={{fontSize:11,fontWeight:700,color:'var(--gold)',marginBottom:8,display:'flex',alignItems:'center',gap:5}}>
                    <span>📚</span> Ressources associées
                  </div>
                  <div style={{display:'flex',flexWrap:'wrap',gap:8}}>
                    {chapRes.slice(0,4).map(r=>(
                      <div key={r.id} style={{background:'white',border:'1.5px solid #C8D8F5',borderRadius:2,padding:'7px 11px',display:'flex',alignItems:'center',gap:8,maxWidth:280}}>
                        <span style={{fontSize:16,flexShrink:0}}>{r.type==='fiche'?'📄':r.type==='exercice'?'✏️':r.type==='cours'?'📘':'📝'}</span>
                        <div style={{minWidth:0}}>
                          <div style={{fontSize:12,fontWeight:600,overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}>{r.title}</div>
                          <div style={{fontSize:10,color:'var(--muted)'}}>{r.niveau}</div>
                        </div>
                      </div>
                    ))}
                    {chapRes.length>4&&<div style={{fontSize:11,color:'var(--muted)',padding:'7px 0',alignSelf:'center'}}>+{chapRes.length-4} autres…</div>}
                  </div>
                </div>}
              </div>}
            </div>;
          })}

          {/* Resources not attached to a specific chapter */}
          {(()=>{
            const matRes=visibleResources.filter(r=>(r.matiere===mat||r.matiere==='Multi')&&!Object.keys(chaps).includes(r.chapitre||''));
            if(matRes.length===0)return null;
            return <div style={{background:'#F7FAFF',border:'1.5px dashed #C8D8F5',borderRadius:0,padding:'12px 16px',marginBottom:8}}>
              <div style={{fontSize:11,fontWeight:700,color:'var(--gold)',marginBottom:8}}>📚 Autres ressources — {mat}</div>
              <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fill,minmax(220px,1fr))',gap:8}}>
                {matRes.slice(0,6).map(r=>(
                  <div key={r.id} style={{background:'white',border:'1.5px solid #C8D8F5',borderRadius:2,padding:'8px 12px',display:'flex',alignItems:'center',gap:8}}>
                    <span style={{fontSize:16,flexShrink:0}}>{r.type==='fiche'?'📄':r.type==='exercice'?'✏️':r.type==='cours'?'📘':'📝'}</span>
                    <div style={{minWidth:0}}>
                      <div style={{fontSize:12,fontWeight:600,overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}>{r.title}</div>
                      <div style={{fontSize:10,color:'var(--muted)'}}>{r.type} · {r.niveau}</div>
                    </div>
                  </div>
                ))}
              </div>
            </div>;
          })()}
        </div>
      ))}
    </div>
  </>;
}


function Bibliotheque({user,users,resources,setResources,cours=[],compEtats={}}){
  const [ft,setFt]=useState('Tous');
  const [fm,setFm]=useState('Toutes');
  const [q,setQ]=useState('');
  const [show,setShow]=useState(false);
  const [showGN,setShowGN]=useState(false);
  const [form,setForm]=useState({title:'',type:'trace',matiere:'Mathématiques',niveau:'3ème',desc:'',devoirs:'',commentaires:''});
  const [gnStep,setGnStep]=useState('upload');
  const [gnFile,setGnFile]=useState(null);
  const [gnPreview,setGnPreview]=useState(null);
  const [gnError,setGnError]=useState('');
  const canM=user.role==='admin'||user.role==='prof';
  // Élève : ses matières + son niveau uniquement
  const myMatieres=useMemo(()=>{
    if(user.role!=='eleve')return null; // null = no filter
    const myCours=cours.filter(c=>c.eleveIds.includes(user.id));
    return new Set(myCours.map(c=>c.matiere));
  },[user,cours]);
  // Compétences en cours/à revoir pour l'élève — pour suggestions
  const myCompSuggestions=useMemo(()=>{
    if(user.role!=='eleve')return new Set();
    const etats=compEtats[user.id]||{};
    return new Set(
      COMP_TEMPLATES
        .filter(t=>{const s=etats[t.id]?.statut;return s==='en_cours'||s==='a_revoir';})
        .map(t=>t.matiere)
    );
  },[user,compEtats]);

  const TYPES=['Tous','fiche','exercice','trace','cours'];
  const filtered=useMemo(()=>resources.filter(r=>{
    // Élève : voir seulement ses matières
    if(myMatieres&&!myMatieres.has(r.matiere)&&r.matiere!=='Multi'&&r.matiere!=='Général')return false;
    if(ft!=='Tous'&&r.type!==ft)return false;
    if(fm!=='Toutes'&&r.matiere!==fm)return false;
    if(q&&!r.title.toLowerCase().includes(q.toLowerCase()))return false;
    return true;
  }),[resources,ft,fm,q,myMatieres]);
  const add=()=>{if(!form.title.trim())return;setResources(p=>[...p,{id:'r'+Date.now(),...form,auteurId:user.id,date:new Date().toISOString().split('T')[0],dl:0}]);setShow(false);setForm({title:'',type:'trace',matiere:'Mathématiques',niveau:'3ème',desc:'',devoirs:'',commentaires:''});};
  const del=(id)=>setResources(p=>p.filter(r=>r.id!==id));
  const dl=(res)=>{setResources(p=>p.map(r=>r.id===res.id?{...r,dl:r.dl+1}:r));alert(`📥 "${res.title}"\n\nTéléchargement simulé.`);};
  const openGN=()=>{setGnStep('upload');setGnFile(null);setGnPreview(null);setGnError('');setShowGN(true);};
  const handleGNFile=(file)=>{
    if(!file)return;
    setGnFile(file);setGnError('');
    if(file.type.startsWith('image/')){const reader=new FileReader();reader.onload=e=>setGnPreview({type:'image',src:e.target.result});reader.readAsDataURL(file);}
    else{setGnPreview({type:'pdf',name:file.name});}
  };
  const analyzeWithClaude=async()=>{
    if(!gnFile){setGnError("Veuillez d'abord sélectionner un fichier.");return;}
    setGnStep('analyzing');
    try{
      const toBase64=f=>new Promise((res,rej)=>{const r=new FileReader();r.onload=()=>res(r.result.split(',')[1]);r.onerror=rej;r.readAsDataURL(f);});
      const b64=await toBase64(gnFile);
      const isImage=gnFile.type.startsWith('image/');
      const mediaType=isImage?gnFile.type:'application/pdf';
      const msgContent=[
        {type:isImage?'image':'document',source:{type:'base64',media_type:mediaType,data:b64}},
        {type:'text',text:'Tu es un assistant pédagogique. Analyse ce document (trace écrite, export GoodNotes) et extrais en JSON strict sans markdown :\n{"titre":"titre du cours","matiere":"Mathématiques|Physique|Français|Histoire|Multi","niveau":"5ème|4ème|3ème|Lycée|Terminale|Collège","description":"résumé 2-3 phrases","devoirs":"devoirs à faire ou chaine vide","commentaires":"commentaires du prof ou chaine vide"}\nRéponds UNIQUEMENT avec le JSON.'}
      ];
      const resp=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,messages:[{role:'user',content:msgContent}]})});
      const data=await resp.json();
      const text=data.content?.find(c=>c.type==='text')?.text||'';
      let parsed;
      try{parsed=JSON.parse(text.replace(/```json|```/g,'').trim());}catch(e){throw new Error("Réponse inattendue. Réessayez.");}
      setForm({title:parsed.titre||'',type:'trace',matiere:parsed.matiere||'Mathématiques',niveau:parsed.niveau||'3ème',desc:parsed.description||'',devoirs:parsed.devoirs||'',commentaires:parsed.commentaires||''});
      setGnStep('result');
    }catch(e){setGnError(e.message||"Erreur lors de l'analyse.");setGnStep('upload');}
  };
  const publishFromGN=()=>{
    if(!form.title.trim())return;
    setResources(p=>[...p,{id:'r'+Date.now(),...form,auteurId:user.id,date:new Date().toISOString().split('T')[0],dl:0,gnImport:true}]);
    setShowGN(false);setGnStep('upload');
  };
  return <>
    <TB title="Bibliothèque">
      <div className="sw"><input className="si" style={{width:190}} placeholder="Rechercher..." value={q} onChange={e=>setQ(e.target.value)}/></div>
      {user.role==='prof'&&<button className="btn btn-o" onClick={openGN}>📲 GoodNotes</button>}
      {canM&&<button className="btn btn-p" onClick={()=>setShow(true)}>＋ Ajouter</button>}
    </TB>
    <div className="pg">
      <div className="fb">
        <span style={{fontSize:11,fontWeight:600,color:'var(--muted)',alignSelf:'center',marginRight:3}}>Type :</span>
