      )}
    </div>
    {show&&<Modal title="Ajouter une ressource" onClose={()=>setShow(false)}>
      <div className="fg"><label className="fl">Titre *</label><input className="fi" value={form.title} onChange={e=>setForm({...form,title:e.target.value})} placeholder="Ex: Fiche — Les dérivées"/></div>
      <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:10}}>
        <div className="fg"><label className="fl">Type</label><select className="fi" value={form.type} onChange={e=>setForm({...form,type:e.target.value})}>{['fiche','exercice','trace','cours'].map(t=><option key={t} value={t}>{TL[t]}</option>)}</select></div>
        <div className="fg"><label className="fl">Matière</label><select className="fi" value={form.matiere} onChange={e=>setForm({...form,matiere:e.target.value})}>{MATIERES.filter(m=>m!=='Toutes').map(m=><option key={m}>{m}</option>)}</select></div>
        <div className="fg"><label className="fl">Niveau</label><select className="fi" value={form.niveau} onChange={e=>setForm({...form,niveau:e.target.value})}>{NIVEAUX.filter(n=>n!=='Tous').map(n=><option key={n}>{n}</option>)}</select></div>
      </div>
      <div className="fg"><label className="fl">Description</label><textarea className="fi" value={form.desc} onChange={e=>setForm({...form,desc:e.target.value})}/></div>
      <div className="fg"><label className="fl">Fichier</label><input type="file" className="fi" accept=".pdf,.docx,.pptx"/></div>
      <div className="fa"><button className="btn btn-o" onClick={()=>setShow(false)}>Annuler</button><button className="btn btn-p" onClick={add}>Publier</button></div>
    </Modal>}
    {showGN&&<Modal title="📲 Import depuis GoodNotes" onClose={()=>setShowGN(false)}>
      {gnStep==='upload'&&<>
        <p style={{fontSize:13,color:'var(--muted)',marginBottom:14}}>Exportez votre trace depuis GoodNotes en <strong>PDF ou image</strong>. Claude analyse automatiquement le contenu, les devoirs et les commentaires.</p>
        <div className="gn-dropzone"
          onDragOver={e=>{e.preventDefault();e.currentTarget.classList.add('drag');}}
