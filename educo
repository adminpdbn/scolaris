// ─── FACTURATION ───
function Facturation({user,users,factures,setFactures,cours}){
  const [tab,setTab]=useState('vue');
  const [open,setOpen]=useState({});
  const [showFact,setShowFact]=useState(false);
  const [factForm,setFactForm]=useState({familleId:'',eleveId:'',libelle:'',type:'mensuel',montant:'',echeance:'',statut:'attente',nbCreneaux:0});
  // Inline edit state
  const [editId,setEditId]=useState(null);
  const [editRow,setEditRow]=useState({});

  // ── Groupement automatique par nom de famille ──
  const familles=useMemo(()=>{
    const eleves=users.filter(u=>u.role==='eleve');
    const map={};
    eleves.forEach(e=>{
      const lastName=e.name.trim().split(/\s+/).slice(-1)[0];
      const id='fam_'+lastName.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g,'');
      if(!map[id]){map[id]={id,nom:'Famille '+lastName,lastName,eleveIds:[e.id]};}
      else if(!map[id].eleveIds.includes(e.id)){map[id].eleveIds.push(e.id);}
    });
    return Object.values(map).sort((a,b)=>a.lastName.localeCompare(b.lastName));
  },[users]);

  // ── Calcul tarif auto ──
  const TARIF=55;
  const getEleveSessions=(eleveId)=>cours.filter(c=>c.eleveIds.includes(eleveId));
  const getEleveCreneaux=(eleveId)=>getEleveSessions(eleveId).length;
  const getEleveMontant=(eleveId)=>{
    const mats=new Set(getEleveSessions(eleveId).map(c=>c.matiere));
    return mats.size*TARIF;
  };
  const getEleveLabel=(eleveId)=>{
    const e=users.find(u=>u.id===eleveId);
    const sessions=getEleveSessions(eleveId);
    const mats=[...new Set(sessions.map(c=>c.matiere))];
    const month=new Date().toLocaleString('fr-FR',{month:'long',year:'numeric'});
    return e?`Forfait ${mats.join(' + ')} — ${e.name} — ${month}`:'';
  };

  // ── Calcul tarif auto : 55€/mois par matière ──
  const getFamTarif=(fam)=>{
    const eleveIds=fam.eleveIds;
    const matieres=new Set(
      cours.filter(c=>c.eleveIds.some(eid=>eleveIds.includes(eid))).map(c=>c.matiere)
    );
    return matieres.size*55;
  };
  const getFamMatieres=(fam)=>{
    const eleveIds=fam.eleveIds;
    return [...new Set(cours.filter(c=>c.eleveIds.some(eid=>eleveIds.includes(eid))).map(c=>c.matiere))];
  };
  const famFacts=(fid)=>factures.filter(f=>f.familleId===fid);
  const totalFam=(fid)=>famFacts(fid).reduce((a,f)=>a+f.montant,0);
  const payeFam=(fid)=>famFacts(fid).filter(f=>f.statut==='paye').reduce((a,f)=>a+f.montant,0);
  const pendingFam=(fid)=>famFacts(fid).filter(f=>f.statut!=='paye').length;
  const toggle=(id)=>setOpen(p=>({...p,[id]:!p[id]}));

  const setStatut=(id,statut)=>setFactures(p=>p.map(f=>f.id===id?{...f,statut,datePaiement:statut==='paye'?new Date().toISOString().split('T')[0]:null}:f));
  const delFact=(id)=>setFactures(p=>p.filter(f=>f.id!==id));
  const addFact=()=>{
    if(!factForm.libelle||!factForm.montant||!factForm.familleId)return;
    setFactures(p=>[...p,{id:'fc'+Date.now(),...factForm,montant:parseFloat(factForm.montant),eleveId:factForm.eleveId||null,nbCreneaux:factForm.nbCreneaux||0,datePaiement:factForm.statut==='paye'?new Date().toISOString().split('T')[0]:null}]);
    setShowFact(false); setFactForm({familleId:'',eleveId:'',libelle:'',type:'mensuel',montant:'',echeance:'',statut:'attente',nbCreneaux:0});
  };
  // Inline edit
  const startEdit=(f)=>{setEditId(f.id);setEditRow({libelle:f.libelle,montant:String(f.montant),echeance:f.echeance,statut:f.statut});};
  const saveEdit=(id)=>{
    setFactures(p=>p.map(f=>f.id===id?{...f,...editRow,montant:parseFloat(editRow.montant),datePaiement:editRow.statut==='paye'&&f.statut!=='paye'?new Date().toISOString().split('T')[0]:f.datePaiement}:f));
    setEditId(null);
  };

  const totalGlobal=factures.reduce((a,f)=>a+f.montant,0);
  const totalPaye=factures.filter(f=>f.statut==='paye').reduce((a,f)=>a+f.montant,0);
  const totalAttente=factures.filter(f=>f.statut==='attente').reduce((a,f)=>a+f.montant,0);
  const totalRetard=factures.filter(f=>f.statut==='retard').reduce((a,f)=>a+f.montant,0);
  const nbRetard=factures.filter(f=>f.statut==='retard').length;

  const SBadge=({s})=>{
    const map={paye:{cls:'s-paye',icon:'✓',label:'Payé'},attente:{cls:'s-attente',icon:'⏳',label:'En attente'},retard:{cls:'s-retard',icon:'⚠️',label:'En retard'}};
    const m=map[s]||map['attente'];
    return <span className={`stat-badge ${m.cls}`}>{m.icon} {m.label}</span>;
  };

  return <>
    <TB title="Facturation">
      <button className="btn btn-sm" style={{background:'var(--cream2)',border:'none',color:'var(--muted)',fontSize:11}} onClick={()=>{if(window.confirm('Remettre les factures de démonstration ?'))setFactures(SEED_FACTURES);}}>↺ Reset démo</button>
      <button className="btn btn-p btn-sm" onClick={()=>setShowFact(true)}>＋ Facture</button>
    </TB>
    <div className="pg">
      <div style={{background:'#EEF5FF',border:'1.5px solid rgba(26,111,212,.2)',borderRadius:0,padding:'8px 14px',marginBottom:18,fontSize:12,color:'#a04010',display:'flex',alignItems:'center',gap:7}}>
        <span>✨</span> Les familles sont détectées automatiquement depuis les noms de famille des élèves inscrits.
      </div>
      <div className="sg" style={{marginBottom:22}}>
        <div className="sc c-navy"><div className="sc-ic">💶</div><div className="sc-v">{totalGlobal}€</div><div className="sc-l">Total facturé</div></div>
        <div className="sc c-ok"><div className="sc-ic">✅</div><div className="sc-v">{totalPaye}€</div><div className="sc-l">Encaissé</div></div>
        <div className="sc c-gold"><div className="sc-ic">⏳</div><div className="sc-v">{totalAttente}€</div><div className="sc-l">En attente</div></div>
        <div className="sc"><div className="sc-ic">⚠️</div><div className="sc-v" style={{color:'var(--err)'}}>{totalRetard}€</div><div className="sc-l">{nbRetard} facture{nbRetard>1?'s':''} en retard</div></div>
      </div>

      <div className="tabs" style={{maxWidth:320}}>
        <button className={`tab ${tab==='vue'?'on':''}`} onClick={()=>setTab('vue')}>👨‍👩‍👧 Par famille</button>
        <button className={`tab ${tab==='liste'?'on':''}`} onClick={()=>setTab('liste')}>📋 Toutes les factures</button>
      </div>

      {tab==='vue'&&<div style={{display:'flex',flexDirection:'column',gap:12}}>
        {familles.length===0&&<div className="emp"><div className="emp-icon">👨‍👩‍👧</div><h3>Aucun élève inscrit</h3><p>Ajoutez des élèves pour voir les familles apparaître.</p></div>}
        {familles.map(fam=>{
          const facts=famFacts(fam.id);
          const tp=totalFam(fam.id); const pp=payeFam(fam.id); const pend=pendingFam(fam.id);
          const pct=tp>0?Math.round((pp/tp)*100):0;
          const famEleves=users.filter(u=>fam.eleveIds.includes(u.id));
          return <div key={fam.id} className="fam-card">
            <div className="fam-hd" onClick={()=>toggle(fam.id)}>
              <div style={{display:'flex',alignItems:'center',gap:10}}>
                <div style={{width:38,height:38,borderRadius:0,background:'var(--navy)',display:'flex',alignItems:'center',justifyContent:'center',fontSize:17,flexShrink:0}}>👨‍👩‍👧</div>
                <div>
                  <div className="fam-name">{fam.nom}</div>
                  <div className="fam-sub">
                    {famEleves.map(e=>(
                      <span key={e.id} style={{display:'inline-flex',alignItems:'center',gap:3,marginRight:6}}>
                        🎓 {e.name} <span style={{fontSize:10,opacity:.6}}>({e.niveau})</span>
                      </span>
                    ))}
                    {famEleves.length===0&&<span style={{fontStyle:'italic'}}>Aucun élève actif</span>}
                  </div>
                  {getFamMatieres(fam).length>0&&<div style={{marginTop:4,display:'flex',gap:5,flexWrap:'wrap'}}>
                    {getFamMatieres(fam).map(m=><span key={m} style={{...getCoursBadge(m),fontSize:10}}>{m}</span>)}
                    <span style={{fontSize:11,fontWeight:700,color:'var(--navy)',marginLeft:4}}>= {getFamTarif(fam)}€/mois</span>
                  </div>}
                </div>
              </div>
              <div style={{display:'flex',alignItems:'center',gap:14}}>
                {pend>0&&<span className={`stat-badge ${facts.some(f=>f.statut==='retard')?'s-retard':'s-attente'}`}>⚠️ {pend} impayée{pend>1?'s':''}</span>}
                {tp>0&&<div style={{textAlign:'right'}}>
                  <div style={{fontFamily:'Playfair Display,serif',fontSize:15,fontWeight:700}}>{pp}€ <span style={{fontSize:11,fontWeight:400,color:'var(--muted)'}}>/ {tp}€</span></div>
                  <div style={{fontSize:10,color:'var(--muted)'}}>{pct}% encaissé</div>
                </div>}
                <span style={{color:'var(--muted)',fontSize:13,marginLeft:4}}>{open[fam.id]?'▲':'▼'}</span>
              </div>
            </div>
            {tp>0&&<div className="pb" style={{borderRadius:0,height:3}}><div className="pbf" style={{width:`${pct}%`,background:pct===100?'var(--ok)':pct>50?'#D97706':'var(--err)'}}/></div>}
            {open[fam.id]&&<div className="fam-bd">
              <div style={{display:'flex',justifyContent:'flex-end',marginBottom:12}}>
                <button className="btn btn-p btn-sm" onClick={()=>{setFactForm(p=>({...p,familleId:fam.id}));setShowFact(true);}}>＋ Facture</button>
              </div>
              {facts.length===0
                ?<div style={{textAlign:'center',padding:'16px 0',color:'var(--muted)',fontSize:13}}>Aucune facture pour cette famille.</div>
                :facts.map(f=>{
                  const isEditing=editId===f.id;
                  return <div key={f.id} className="fact-row" style={{flexDirection:'column',gap:6}}>
                    {isEditing?(
                      <div style={{display:'flex',flexDirection:'column',gap:8,width:'100%'}}>
                        <input className="fi" style={{fontSize:13}} value={editRow.libelle} onChange={e=>setEditRow(r=>({...r,libelle:e.target.value}))} placeholder="Libellé"/>
                        <div style={{display:'flex',gap:8,flexWrap:'wrap'}}>
                          <input className="fi" type="number" style={{width:90,fontSize:12}} value={editRow.montant} onChange={e=>setEditRow(r=>({...r,montant:e.target.value}))} placeholder="Montant €"/>
                          <input className="fi" type="date" style={{fontSize:12}} value={editRow.echeance} onChange={e=>setEditRow(r=>({...r,echeance:e.target.value}))}/>
                          <select className="fi" style={{fontSize:12,flex:1}} value={editRow.statut} onChange={e=>setEditRow(r=>({...r,statut:e.target.value}))}>
                            <option value="paye">✓ Payé</option>
                            <option value="attente">⏳ En attente</option>
                            <option value="retard">⚠️ En retard</option>
                          </select>
                        </div>
                        <div style={{display:'flex',gap:6,justifyContent:'flex-end'}}>
                          <button className="btn btn-o btn-sm" onClick={()=>setEditId(null)}>Annuler</button>
                          <button className="btn btn-p btn-sm" onClick={()=>saveEdit(f.id)}>✓ Sauvegarder</button>
                        </div>
                      </div>
                    ):(
                      <div style={{display:'flex',alignItems:'center',width:'100%',gap:8}}>
                        <div style={{flex:1}}>
                          <div style={{fontSize:13,fontWeight:500}}>{f.libelle}</div>
                          <div style={{fontSize:11,color:'var(--muted)',marginTop:2,display:'flex',gap:10}}>
                            <span>Échéance : {f.echeance||'—'}</span>
                            {f.nbCreneaux>0&&<span>· {f.nbCreneaux} créneau{f.nbCreneaux>1?'x':''}</span>}
                            {f.datePaiement&&<span style={{color:'var(--ok)'}}>· Payé le {f.datePaiement}</span>}
                          </div>
                        </div>
                        <span style={{fontWeight:700,fontSize:14,minWidth:48,textAlign:'right'}}>{f.montant}€</span>
                        <SBadge s={f.statut}/>
                        <button className="btn btn-sm" style={{background:'#f0f4ff',border:'1.5px solid #c8d8f5',color:'var(--info)'}} onClick={()=>startEdit(f)}>✏️</button>
                        <button className="btn btn-d btn-sm" onClick={()=>delFact(f.id)}>🗑️</button>
                      </div>
                    )}
                  </div>;
                })
              }
              {facts.length>0&&<div className="fact-total">
                <span style={{fontSize:12,fontWeight:600}}>Total famille</span>
                <div style={{display:'flex',gap:16,fontSize:13}}>
                  <span style={{color:'var(--ok)',fontWeight:700}}>✓ {pp}€</span>
                  {(tp-pp)>0&&<span style={{color:'var(--err)',fontWeight:700}}>✗ {tp-pp}€</span>}
                  <span style={{fontWeight:700}}>{tp}€</span>
                </div>
              </div>}
            </div>}
          </div>;
        })}
      </div>}

      {tab==='liste'&&<>
        {factures.length===0?<div className="emp"><div className="emp-icon">🧾</div><h3>Aucune facture</h3></div>:(
          <table className="tbl">
            <thead><tr><th>Famille</th><th>Libellé</th><th>Montant</th><th>Échéance</th><th>Statut</th><th></th></tr></thead>
            <tbody>{[...factures].sort((a,b)=>{const o={retard:0,attente:1,paye:2};return(o[a.statut]??1)-(o[b.statut]??1)||a.echeance.localeCompare(b.echeance);}).map(f=>{
              const fam=familles.find(x=>x.id===f.familleId);
              return <tr key={f.id}>
                <td style={{fontWeight:600,fontSize:13}}>{fam?.nom||f.familleId}</td>
                <td style={{fontSize:12}}>{f.libelle}</td>
                <td><span style={{fontFamily:'Playfair Display,serif',fontWeight:700}}>{f.montant}€</span></td>
                <td style={{fontSize:12,color:'var(--muted)'}}>{f.echeance}</td>
                <td><SBadge s={f.statut}/></td>
                <td style={{display:'flex',gap:6,alignItems:'center'}}>
                  <select className="fi" style={{width:'auto',padding:'4px 8px',fontSize:11}} value={f.statut} onChange={e=>setStatut(f.id,e.target.value)}>
                    <option value="paye">✓ Payé</option>
                    <option value="attente">⏳ Attente</option>
                    <option value="retard">⚠️ Retard</option>
                  </select>
                  <button className="btn btn-d btn-sm" onClick={()=>delFact(f.id)}>🗑️</button>
                </td>
              </tr>;
            })}</tbody>
          </table>
        )}
      </>}
    </div>

    {showFact&&<Modal title="Nouvelle facture" onClose={()=>setShowFact(false)}>
      {/* Sélection élève — auto-remplit tout */}
      <div className="fg"><label className="fl">Élève *</label>
        <select className="fi" value={factForm.eleveId} onChange={e=>{
          const eid=e.target.value;
          const eleve=users.find(u=>u.id===eid);
          if(!eleve)return setFactForm({...factForm,eleveId:'',familleId:'',libelle:'',montant:'',nbCreneaux:0});
          // Auto-détect famille
          const ln=eleve.name.trim().split(/\s+/).slice(-1)[0];
          const famId='fam_'+ln.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'');
          const montant=getEleveMontant(eid);
          const nbC=getEleveCreneaux(eid);
          const libelle=getEleveLabel(eid);
          const echDate=new Date();echDate.setDate(1);echDate.setMonth(echDate.getMonth()+1);
          const ech=echDate.toISOString().split('T')[0];
          setFactForm({...factForm,eleveId:eid,familleId:famId,libelle,montant:String(montant),nbCreneaux:nbC,echeance:ech});
        }}>
          <option value="">— Choisir un élève —</option>
          {users.filter(u=>u.role==='eleve').map(e=>{
            const nc=getEleveCreneaux(e.id);
            const mt=getEleveMontant(e.id);
            return <option key={e.id} value={e.id}>{e.name} ({e.niveau}) — {nc} créneau{nc>1?'x':''} → {mt}€/mois</option>;
          })}
        </select>
      </div>
      {/* Aperçu des créneaux de l'élève */}
      {factForm.eleveId&&<div style={{background:'#F0F6FF',border:'1px solid #C8D8F5',borderRadius:2,padding:'10px 14px',marginBottom:4,fontSize:12}}>
        <div style={{fontWeight:600,marginBottom:6,color:'var(--navy)'}}>📅 Créneaux de {users.find(u=>u.id===factForm.eleveId)?.name}</div>
        {getEleveSessions(factForm.eleveId).map(c=>(
          <div key={c.id} style={{display:'flex',alignItems:'center',gap:8,marginBottom:3}}>
            <span style={{...getCoursBadge(c.matiere),fontSize:10,padding:'1px 6px'}}>{c.matiere}</span>
            <span style={{color:'var(--muted)'}}>{c.jour} {hs(c.debut)}–{hs(c.fin)}</span>
            <span style={{color:'var(--muted)'}}>· {users.find(u=>u.id===c.profId)?.name.split(' ').slice(-1)[0]}</span>
          </div>
        ))}
        {getEleveSessions(factForm.eleveId).length===0&&<span style={{color:'var(--muted)',fontStyle:'italic'}}>Aucun créneau inscrit</span>}
      </div>}
      <div className="fg"><label className="fl">Libellé *</label>
        <input className="fi" value={factForm.libelle} onChange={e=>setFactForm({...factForm,libelle:e.target.value})} placeholder="Généré automatiquement depuis l'élève"/>
      </div>
      <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:10}}>
        <div className="fg"><label className="fl">Montant (€) *</label>
          <input className="fi" type="number" value={factForm.montant} onChange={e=>setFactForm({...factForm,montant:e.target.value})}/>
        </div>
        <div className="fg"><label className="fl">Créneaux/mois</label>
          <input className="fi" type="number" value={factForm.nbCreneaux} onChange={e=>setFactForm({...factForm,nbCreneaux:parseInt(e.target.value)||0})}/>
        </div>
        <div className="fg"><label className="fl">Échéance</label><input className="fi" type="date" value={factForm.echeance} onChange={e=>setFactForm({...factForm,echeance:e.target.value})}/></div>
        <div className="fg"><label className="fl">Statut</label>
          <select className="fi" value={factForm.statut} onChange={e=>setFactForm({...factForm,statut:e.target.value})}>
            <option value="attente">⏳ En attente</option><option value="paye">✓ Payé</option><option value="retard">⚠️ En retard</option>
          </select>
        </div>
      </div>
      <div className="fa"><button className="btn btn-o" onClick={()=>setShowFact(false)}>Annuler</button><button className="btn btn-p" onClick={addFact}>Créer la facture</button></div>
    </Modal>}
  </>;
}


// ─── FACTURATION ───

// ─── APP ───
function App(){
  const [cu,setCu]=useState(null);
  const [page,setPage]=useState('dashboard');
  const [appReady,setAppReady]=useState(false); // true quand session vérifiée
  const [dataReady,setDataReady]=useState(false); // true quand données chargées

  const [users,setUsers]=useState(SEED_USERS);
  const [resources,setResources]=useState(SEED_RES);
  const [modules,setModules]=useState(SEED_MOD);
  const [grades,setGrades]=useState(SEED_GRADES);
  const [enrollments,setEnrollments]=useState(SEED_ENR);
  const [cours,setCours]=useState(SEED_COURS);
  const [appel,setAppel]=useState(SEED_APPEL);
  const [factures,setFactures]=useState(SEED_FACTURES);
  const [salaires,setSalaires]=useState(SEED_SALAIRES);
  const [dispos,setDispos]=useState([]);
  const [demandes,setDemandes]=useState([]);
  const [compEtats,setCompEtats]=useState({});
  const [customComps,setCustomComps]=useState([]);
  const [customTrophies,setCustomTrophies]=useState([]);
  const [awardedTrophies,setAwardedTrophies]=useState({});

  // ── Vérification session Supabase au démarrage ──
  useEffect(()=>{
    sb.auth.getSession().then(({data:{session}})=>{
      if(session){
        sb.from('users').select('*').eq('auth_id',session.user.id).single()
          .then(({data:profile})=>{ if(profile) setCu(profile); })
          .finally(()=>setAppReady(true));
      } else { setAppReady(true); }
    });
    const {data:{subscription}} = sb.auth.onAuthStateChange((_event,session)=>{
      if(!session){ setCu(null); setDataReady(false); }
    });
    return ()=>subscription.unsubscribe();
  },[]);

  // ── Chargement des données Supabase quand l'utilisateur est connecté ──
  // Stratégie :
  //   • tables "tableau"  (users, cours, ressources, modules, factures, dispos, demandes, trophees_custom)
  //     → sbLoad()  : rows Supabase ↔ tableau JS  ✓
  //   • données "objet" (appel, grades, enrollments, salaires, awardedTrophies)
  //     → kv_store  : JSONB brut, préserve le format attendu par l'app  ✓
  useEffect(()=>{
    if(!cu) return;
    (async()=>{
      setDataReady(false);
      const [u,r,mo,fa,di,de,ct,
             ap,g,en,sa,at,ce,cc] = await Promise.all([
        // tableaux normalisés
        sbLoad('users',            SEED_USERS),
        sbLoad('ressources',       SEED_RES),
        sbLoad('modules',          SEED_MOD),
        sbLoad('factures',         SEED_FACTURES),
        sbLoad('dispos',           []),
        sbLoad('demandes',         []),
        sbLoad('trophees_custom',  []),
        // objets JSON stockés dans kv_store
        sbLoadKV('appel',           'global', SEED_APPEL),
        sbLoadKV('grades',          'global', SEED_GRADES),
        sbLoadKV('enrollments',     'global', SEED_ENR),
        sbLoadKV('salaires',        'global', SEED_SALAIRES),
        sbLoadKV('trophees_awarded','global', {}),
        sbLoadKV('comp_etats',      cu.id,    {}),
        sbLoadKV('custom_comps',    cu.id,    []),
      ]);
      // cours dans kv_store également (eleveIds est un tableau JSON)
      const co = await sbLoadKV('cours', 'global', SEED_COURS);
      setUsers(u); setResources(r); setModules(mo); setFactures(fa);
      setDispos(di); setDemandes(de); setCustomTrophies(ct);
      setAppel(ap); setGrades(g); setEnrollments(en); setSalaires(sa);
      setAwardedTrophies(at); setCompEtats(ce); setCustomComps(cc);
      setCours(co);
      setDataReady(true);
    })();
  },[cu?.id]);

  // ── Sync retour vers Supabase ──
  useEffect(()=>{ if(dataReady) sbSave('users',           users);           },[users]);
  useEffect(()=>{ if(dataReady) sbSave('ressources',      resources);       },[resources]);
  useEffect(()=>{ if(dataReady) sbSave('modules',         modules);         },[modules]);
  useEffect(()=>{ if(dataReady) sbSave('factures',        factures);        },[factures]);
  useEffect(()=>{ if(dataReady) sbSave('dispos',          dispos);          },[dispos]);
  useEffect(()=>{ if(dataReady) sbSave('demandes',        demandes);        },[demandes]);
  useEffect(()=>{ if(dataReady) sbSave('trophees_custom', customTrophies);  },[customTrophies]);
  // objets → kv_store
  useEffect(()=>{ if(dataReady) sbSaveKV('cours',            cours,           'global'); },[cours]);
  useEffect(()=>{ if(dataReady) sbSaveKV('appel',            appel,           'global'); },[appel]);
  useEffect(()=>{ if(dataReady) sbSaveKV('grades',           grades,          'global'); },[grades]);
  useEffect(()=>{ if(dataReady) sbSaveKV('enrollments',      enrollments,     'global'); },[enrollments]);
  useEffect(()=>{ if(dataReady) sbSaveKV('salaires',         salaires,        'global'); },[salaires]);
  useEffect(()=>{ if(dataReady) sbSaveKV('trophees_awarded', awardedTrophies, 'global'); },[awardedTrophies]);
  useEffect(()=>{ if(dataReady&&cu) sbSaveKV('comp_etats',   compEtats,  cu.id); },[compEtats]);
  useEffect(()=>{ if(dataReady&&cu) sbSaveKV('custom_comps', customComps,cu.id); },[customComps]);

  const login=(u)=>{ setCu(u); setPage('dashboard'); };
  const logout=async()=>{ await sb.auth.signOut(); setCu(null); };

  if(!appReady) return <div style={{display:'flex',alignItems:'center',justifyContent:'center',minHeight:'100vh',background:'#111',color:'var(--gold)',fontFamily:'var(--ff-mono)',fontSize:14,letterSpacing:1}}>⟳ Chargement…</div>;

  if(!cu)return<Login onLogin={login}/>;

  if(!dataReady) return <div style={{display:'flex',alignItems:'center',justifyContent:'center',minHeight:'100vh',background:'var(--cream2)',color:'var(--navy)',fontFamily:'var(--ff-mono)',fontSize:13,letterSpacing:.5}}>
    <div style={{textAlign:'center'}}>
      <div style={{fontSize:28,marginBottom:12}}>📚</div>
      <div>Chargement des données…</div>
    </div>
  </div>;

  const props={user:cu,users,setUsers,resources,setResources,modules,setModules,grades,setGrades,enrollments,setEnrollments,cours,setCours,appel,setAppel,factures,setFactures,salaires,setSalaires,dispos,setDispos,demandes,setDemandes,compEtats,setCompEtats,customComps,setCustomComps,customTrophies,setCustomTrophies,awardedTrophies,setAwardedTrophies};

  const renderPage=()=>{switch(page){
    case'dashboard':return<Dashboard {...props}/>;
    case'programme':return<MonProgramme {...props} customComps={props.customComps}/>;
    case'bibliotheque':return<Bibliotheque {...props} cours={props.cours} compEtats={props.compEtats}/>;
    case'emploidutemps':return<EmploiDuTemps {...props} setCours={props.setCours} dispos={props.dispos}/>;
    case'modules':return<Modules {...props}/>;
    case'monespace':return<MonEspace {...props}/>;
    case'meseleves':return<MesEleves {...props}/>;
    case'statistiques':return<Statistiques {...props}/>;
    case'facturation':return<Facturation {...props} cours={props.cours}/>;
    case'suivi':return<SuiviCompetences {...props} customComps={props.customComps} setCustomComps={props.setCustomComps} awardedTrophies={props.awardedTrophies} setAwardedTrophies={props.setAwardedTrophies}/>;
    case'coursparticuliers':return<CoursParticuliers {...props}/>;
    case'admin':return<Admin {...props} customTrophies={props.customTrophies} setCustomTrophies={props.setCustomTrophies} awardedTrophies={props.awardedTrophies} setAwardedTrophies={props.setAwardedTrophies}/>;
    default:return<Dashboard {...props}/>;
  }};

  return <div className="app">
    <Sidebar user={cu} page={page} setPage={setPage} onLogout={logout}/>
    <div className="main">{renderPage()}</div>
  </div>;
}
ReactDOM.createRoot(document.getElementById('root')).render(<App/>);
</script>
</body>
</html>
