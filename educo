        <div style={{fontSize:13,color:'var(--muted)',textAlign:'center',maxWidth:280}}>Claude lit votre trace écrite et extrait les informations pédagogiques.</div>
      </div>}
      {gnStep==='result'&&<>
        <div style={{background:'#EEFFF6',border:'1.5px solid #2D9B6F',borderRadius:0,padding:'8px 14px',marginBottom:14,fontSize:12,color:'#1a6b46'}}>✅ Analyse terminée — vérifiez avant de publier.</div>
        <div className="fg"><label className="fl">Titre</label><input className="fi" value={form.title} onChange={e=>setForm({...form,title:e.target.value})}/></div>
        <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:10}}>
          <div className="fg"><label className="fl">Matière</label><select className="fi" value={form.matiere} onChange={e=>setForm({...form,matiere:e.target.value})}>{MATIERES.filter(m=>m!=='Toutes').map(m=><option key={m}>{m}</option>)}</select></div>
          <div className="fg"><label className="fl">Niveau</label><select className="fi" value={form.niveau} onChange={e=>setForm({...form,niveau:e.target.value})}>{NIVEAUX.filter(n=>n!=='Tous').map(n=><option key={n}>{n}</option>)}</select></div>
        </div>
        <div className="fg"><label className="fl">Description</label><textarea className="fi" value={form.desc} onChange={e=>setForm({...form,desc:e.target.value})}/></div>
        <div className="fg"><label className="fl">📌 Devoirs à faire</label><textarea className="fi" style={{minHeight:52}} value={form.devoirs} onChange={e=>setForm({...form,devoirs:e.target.value})} placeholder="Aucun devoir détecté"/></div>
        <div className="fg"><label className="fl">💬 Commentaires professeur</label><textarea className="fi" style={{minHeight:52}} value={form.commentaires} onChange={e=>setForm({...form,commentaires:e.target.value})} placeholder="Aucun commentaire détecté"/></div>
        <div className="fa"><button className="btn btn-o" onClick={()=>setGnStep('upload')}>← Réimporter</button><button className="btn btn-p" onClick={publishFromGN}>✅ Publier</button></div>
      </>}
    </Modal>}
  </>;
}


