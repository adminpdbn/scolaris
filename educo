<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Plus de bonnes notes — Soutien Scolaire v4</title>
<script src="https://unpkg.com/react@18/umd/react.development.js"></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Special+Elite&family=Courier+Prime:ital,wght@0,400;0,700;1,400&family=Caveat:wght@400;600&display=swap" rel="stylesheet"/>
<style>
/* ── LO-FI THEME ── */
:root{
  --navy:#1a1a1a;
  --navy2:#2a2a2a;
  --gold:#8b6200;
  --gold2:#c9a84c;
  --cream:#f5f0e8;
  --cream2:#e8e0d0;
  --text:#1a1a1a;
  --muted:#666;
  --white:#faf7f2;
  --ok:#3a6b3a;
  --err:#8b2222;
  --info:#1a3d6b;
  --sw:210px;
  --ff-mono:'Courier Prime',monospace;
  --ff-serif:'Special Elite',serif;
  --ff-hand:'Caveat',cursive;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:var(--ff-mono);background:var(--cream);color:var(--text);min-height:100vh;
  background-image:repeating-linear-gradient(0deg,rgba(0,0,0,.025) 0,rgba(0,0,0,.025) 1px,transparent 1px,transparent 28px);}
::-webkit-scrollbar{width:5px;}::-webkit-scrollbar-track{background:var(--cream2);}::-webkit-scrollbar-thumb{background:#aaa;border-radius:0;}

/* LOGIN */
.ls{display:flex;min-height:100vh;background:#111;}
.ls-left{flex:1;display:flex;flex-direction:column;justify-content:flex-end;padding:52px 60px;position:relative;overflow:hidden;background:#111;}
.ls-left::before{content:'';position:absolute;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.52);pointer-events:none;z-index:1;}
.ls-classroom{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;pointer-events:none;z-index:0;opacity:.18;filter:grayscale(1);}
.ls-inner{position:relative;z-index:2;padding-bottom:8px;}
.ls-badge{display:inline-flex;align-items:center;gap:7px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.2);border-radius:2px;padding:4px 12px 4px 8px;margin-bottom:28px;}
.ls-badge-dot{width:6px;height:6px;border-radius:50%;background:#c9a84c;animation:pulse 2s ease infinite;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.ls-badge-txt{font-family:var(--ff-mono);font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.6);}
.ls-tag{font-family:var(--ff-serif);font-size:52px;color:#f5f0e8;font-weight:400;line-height:1.05;letter-spacing:1px;margin-bottom:20px;}
.ls-tag strong{color:#c9a84c;}
.ls-tag em{color:#aaa;font-style:italic;}
.ls-desc{color:rgba(255,255,255,.4);font-family:var(--ff-mono);font-size:13px;line-height:1.8;max-width:360px;margin-bottom:44px;}
.ls-stats{display:flex;gap:0;border-top:1px solid rgba(255,255,255,.1);padding-top:28px;}
.ls-stat{flex:1;padding-right:24px;}
.ls-stat:not(:last-child){border-right:1px solid rgba(255,255,255,.1);margin-right:24px;}
.ls-stat-n{font-family:var(--ff-serif);font-size:32px;color:#f5f0e8;line-height:1;}
.ls-stat-l{font-size:10px;letter-spacing:.8px;text-transform:uppercase;color:rgba(255,255,255,.3);margin-top:4px;}
.ls-brand-top{position:absolute;top:48px;left:60px;z-index:3;display:flex;align-items:center;gap:10px;}
.ls-brand-top-name{font-family:var(--ff-mono);font-size:12px;color:rgba(255,255,255,.5);letter-spacing:.5px;}
.ls-right{width:420px;background:var(--cream);display:flex;flex-direction:column;justify-content:center;padding:52px 44px;position:relative;border-left:2px solid #333;}
.ls-right-head{margin-bottom:32px;}
.ls-right-head h2{font-family:var(--ff-serif);font-size:28px;color:var(--navy);line-height:1.2;margin-bottom:6px;}
.ls-right-head p{font-size:12px;color:var(--muted);}

/* Profile cards */
.rc-card{border:1.5px solid var(--cream2);border-radius:2px;padding:13px 16px;cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:12px;background:var(--white);margin-bottom:8px;position:relative;}
.rc-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:transparent;}
.rc-card:hover{border-color:#aaa;background:#f0ebe0;}
.rc-card:hover::before{background:var(--gold2);}
.rc-card.on{border-color:#aaa;background:#f0ebe0;}
.rc-card.on::before{background:var(--gold2);}
.rc-card.on .rn{color:var(--navy);}
.rc-icon-wrap{width:38px;height:38px;border-radius:2px;background:var(--cream2);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.ri{font-size:18px;line-height:1;}
.rn{font-family:var(--ff-mono);font-weight:700;font-size:13px;color:var(--navy);}
.rd{font-size:11px;color:var(--muted);margin-top:2px;}
.rc-check{width:16px;height:16px;border-radius:0;border:1.5px solid #bbb;margin-left:auto;flex-shrink:0;display:flex;align-items:center;justify-content:center;}
.rc-card.on .rc-check{background:var(--navy);border-color:var(--navy);}
.rc-check-inner{width:5px;height:5px;background:var(--cream);opacity:0;}
.rc-card.on .rc-check-inner{opacity:1;}
.ls-btn{width:100%;padding:12px;background:var(--navy);color:var(--cream);border:none;border-radius:2px;font-size:13px;font-family:var(--ff-mono);letter-spacing:.5px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;margin-top:16px;transition:all .15s;}
.ls-btn:hover:not(:disabled){background:#333;}
.ls-btn:disabled{opacity:.3;cursor:not-allowed;}
.ls-btn-arrow{font-size:14px;}
.ls-right-footer{position:absolute;bottom:24px;left:44px;right:44px;display:flex;align-items:center;justify-content:center;}
.ls-right-footer-txt{font-size:10px;color:#bbb;letter-spacing:.5px;}

/* LAYOUT */
.app{display:flex;min-height:100vh;}
.sidebar{width:var(--sw);background:#1a1a1a;display:flex;flex-direction:column;position:fixed;top:0;left:0;height:100vh;z-index:100;border-right:2px solid #333;}
.sb-brand{padding:18px 14px 14px;border-bottom:1px solid #333;}
.sb-logo{font-size:18px;margin-bottom:2px;}
.sb-title{font-family:var(--ff-serif);font-size:15px;color:#f5f0e8;letter-spacing:.5px;}
.sb-sub{font-size:9px;color:#444;text-transform:uppercase;letter-spacing:1px;margin-top:2px;}
.sb-nav{flex:1;padding:10px 8px;overflow-y:auto;}
.sb-sec{font-size:9px;text-transform:uppercase;letter-spacing:1.5px;color:#444;padding:10px 8px 4px;}
.ni{display:flex;align-items:center;gap:8px;padding:7px 8px;border-radius:0;cursor:pointer;color:#666;font-size:11px;font-family:var(--ff-mono);transition:all .1s;margin-bottom:1px;border-left:2px solid transparent;}
.ni:hover{background:rgba(255,255,255,.05);color:#ccc;border-left-color:#555;}
.ni.on{background:#2a2a2a;color:#f5f0e8;border-left:2px solid var(--gold2);font-weight:700;}
.ni-ic{font-size:13px;width:16px;text-align:center;}
.sb-user{padding:12px 14px;border-top:1px solid #333;display:flex;align-items:center;gap:8px;}
.sb-av{width:30px;height:30px;border-radius:2px;background:#333;border:1px solid #555;display:flex;align-items:center;justify-content:center;font-size:11px;font-family:var(--ff-mono);color:var(--gold2);flex-shrink:0;}
.sb-uname{font-size:12px;font-family:var(--ff-mono);color:#ccc;}
.sb-urole{font-size:9px;color:#555;letter-spacing:.5px;}
.sb-out{margin-left:auto;background:none;border:none;color:#444;cursor:pointer;font-size:15px;padding:3px;transition:color .15s;}
.sb-out:hover{color:var(--err);}
.main{margin-left:var(--sw);flex:1;min-height:100vh;}

/* TOPBAR */
.topbar{background:var(--cream);border-bottom:2px solid #2a2a2a;padding:0 24px;height:54px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;}
.tb-ttl{font-family:var(--ff-serif);font-size:17px;color:var(--navy);letter-spacing:.5px;}
.tb-act{display:flex;align-items:center;gap:8px;}

/* PAGE */
.pg{padding:20px 24px;}

/* BUTTONS */
.btn{padding:6px 13px;border-radius:2px;border:1.5px solid var(--navy);font-family:var(--ff-mono);font-size:11px;cursor:pointer;transition:all .12s;display:inline-flex;align-items:center;gap:5px;background:transparent;color:var(--navy);}
.btn-p{background:var(--navy);color:var(--cream);border-color:var(--navy);}
.btn-p:hover{background:#333;}
.btn-o{background:transparent;border-color:var(--cream2);color:var(--text);}
.btn-o:hover{border-color:var(--navy);}
.btn-d{background:transparent;color:var(--err);border:1.5px solid #d5a0a0;}
.btn-d:hover{background:var(--err);color:var(--cream);}
.btn-sm{padding:4px 9px;font-size:10px;}
.btn:disabled{opacity:.35;cursor:not-allowed;}

/* STAT CARDS */
.sg{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:12px;margin-bottom:20px;}
.sc{background:var(--white);border-radius:0;padding:16px;position:relative;overflow:hidden;border:1.5px solid #ccc;border-bottom:3px solid var(--navy);}
.sc::before{display:none;}
.sc-ic{font-size:20px;margin-bottom:8px;opacity:.7;}
.sc-v{font-family:var(--ff-serif);font-size:26px;font-weight:400;line-height:1;margin-bottom:2px;}
.sc-l{font-size:10px;color:var(--muted);letter-spacing:.5px;text-transform:uppercase;}
.c-gold .sc-v{color:var(--gold);}
.c-navy .sc-v{color:var(--navy);}
.c-ok .sc-v{color:var(--ok);}
.c-info .sc-v{color:var(--info);}

/* RESOURCE CARDS */
.rg{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:12px;}
.res-card{background:var(--white);border-radius:0;padding:15px;border:1.5px solid var(--cream2);transition:all .15s;}
.res-card:hover{border-color:#aaa;}
.rtag{display:inline-flex;align-items:center;gap:4px;padding:2px 7px;border-radius:0;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;margin-bottom:8px;border:1px solid;}
.t-f{background:#dde6f0;color:#1a3d6b;border-color:#1a3d6b;}
.t-e{background:#f5ede0;color:#6b3a1a;border-color:#6b3a1a;}
.t-t{background:#ddf0e4;color:#1a5c3a;border-color:#1a5c3a;}
.t-c{background:#ede0f5;color:#4a1a6b;border-color:#4a1a6b;}
.rc-ttl{font-family:var(--ff-mono);font-weight:700;font-size:13px;margin-bottom:5px;line-height:1.4;}
.rc-meta{font-size:11px;color:var(--muted);display:flex;gap:8px;flex-wrap:wrap;}
.rc-foot{margin-top:10px;padding-top:8px;border-top:1px solid var(--cream2);display:flex;justify-content:space-between;align-items:center;}

/* FILTERS */
.fb{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px;}
.chip{padding:4px 10px;border-radius:0;border:1.5px solid var(--cream2);background:var(--white);font-size:11px;cursor:pointer;transition:all .1s;font-family:var(--ff-mono);color:var(--muted);}
.chip:hover,.chip.on{border-color:var(--navy);background:var(--navy);color:var(--cream);}

/* TABLES */
.tbl{width:100%;border-collapse:collapse;background:var(--white);border-radius:0;overflow:hidden;border:1.5px solid #bbb;}
.tbl th{background:var(--navy);color:rgba(245,240,232,.85);text-align:left;padding:9px 13px;font-size:10px;font-family:var(--ff-mono);text-transform:uppercase;letter-spacing:.8px;font-weight:400;}
.tbl td{padding:9px 13px;border-bottom:1px solid var(--cream2);font-size:12px;font-family:var(--ff-mono);}
.tbl tr:last-child td{border-bottom:none;}
.tbl tr:hover td{background:#f0ebe0;}

/* MODAL */
.mo{position:fixed;inset:0;background:rgba(0,0,0,.6);display:flex;align-items:center;justify-content:center;z-index:200;padding:20px;}
.mo-box{background:var(--cream);border-radius:0;padding:24px;width:100%;max-width:480px;max-height:90vh;overflow-y:auto;border:2px solid var(--navy);}
.mo-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;border-bottom:1px solid var(--cream2);padding-bottom:12px;}
.mo-ttl{font-family:var(--ff-serif);font-size:17px;letter-spacing:.5px;}
.mo-x{background:none;border:none;font-size:18px;cursor:pointer;color:var(--muted);line-height:1;font-family:var(--ff-mono);}

/* FORMS */
.fg{margin-bottom:12px;}
.fl{display:block;font-size:10px;font-weight:700;margin-bottom:3px;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);font-family:var(--ff-mono);}
.fi{width:100%;padding:7px 10px;border:1.5px solid var(--cream2);border-radius:0;font-family:var(--ff-mono);font-size:12px;background:var(--white);color:var(--text);}
.fi:focus{outline:none;border-color:var(--navy);}
textarea.fi{resize:vertical;min-height:68px;}
.fa{display:flex;gap:8px;justify-content:flex-end;margin-top:16px;}

/* TROPHIES */
.trg{display:grid;grid-template-columns:repeat(auto-fill,minmax(135px,1fr));gap:10px;}
.tr-card{background:var(--white);border-radius:0;padding:14px 12px;text-align:center;border:1.5px solid var(--cream2);transition:all .15s;}
.tr-card.earned{border-color:var(--gold2);background:#f5f0e0;}
.tr-card.locked{opacity:.3;filter:grayscale(1);}
.tr-icon{font-size:28px;margin-bottom:6px;}
.tr-name{font-size:11px;font-family:var(--ff-mono);font-weight:700;margin-bottom:3px;}
.tr-desc{font-size:10px;color:var(--muted);line-height:1.4;}
.tr-badge{margin-top:5px;font-size:9px;color:var(--gold);font-weight:700;text-transform:uppercase;letter-spacing:.5px;}

/* MODULE CARDS */
.mc{background:var(--white);border-radius:0;overflow:hidden;border:1.5px solid var(--cream2);transition:all .15s;}
.mc:hover{border-color:#aaa;}
.mc-hd{height:80px;display:flex;align-items:center;justify-content:center;font-size:38px;position:relative;background:var(--cream2);}
.mc-bd{padding:12px;}
.mc-ttl{font-family:var(--ff-mono);font-weight:700;font-size:13px;margin-bottom:4px;}
.mc-inf{font-size:11px;color:var(--muted);line-height:1.6;margin-bottom:10px;}

/* WELCOME BANNER */
.wb{background:var(--navy);border-radius:0;padding:22px 26px;color:var(--cream);margin-bottom:20px;position:relative;overflow:hidden;border-left:4px solid var(--gold2);}
.wb::before{content:'//';position:absolute;right:30px;top:16px;font-size:60px;color:rgba(201,168,76,.12);font-family:var(--ff-mono);}
.wb h2{font-family:var(--ff-serif);font-size:20px;margin-bottom:4px;letter-spacing:.5px;}
.wb p{color:rgba(245,240,232,.45);font-size:12px;}
.gold{color:var(--gold2);}

/* NOTE CARDS */
.nc{background:var(--white);border-radius:0;padding:14px;border:1.5px solid var(--cream2);text-align:center;}
.nc-sub{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;font-weight:700;margin-bottom:8px;font-family:var(--ff-mono);}
.nc-v{font-family:var(--ff-serif);font-size:30px;font-weight:400;line-height:1;margin-bottom:2px;}
.nc-max{font-size:11px;color:var(--muted);}
.nc-note{font-size:11px;color:var(--muted);margin-top:4px;line-height:1.4;font-style:italic;}

/* TABS */
.tabs{display:flex;gap:0;background:transparent;padding:0;border-bottom:2px solid var(--navy);margin-bottom:18px;}
.tab{flex:1;padding:7px 12px;text-align:center;border-radius:0;cursor:pointer;font-size:11px;transition:all .1s;color:var(--muted);border:none;background:transparent;font-family:var(--ff-mono);border-bottom:2px solid transparent;margin-bottom:-2px;letter-spacing:.3px;}
.tab.on{background:var(--cream);color:var(--navy);font-weight:700;border-bottom:2px solid var(--cream);border-top:1.5px solid var(--navy);border-left:1.5px solid var(--navy);border-right:1.5px solid var(--navy);}

/* EMPTY */
.emp{text-align:center;padding:48px 20px;color:var(--muted);}
.emp-icon{font-size:36px;margin-bottom:12px;opacity:.3;}
.emp h3{font-family:var(--ff-serif);font-size:16px;color:var(--text);margin-bottom:6px;}
.emp p{font-size:12px;max-width:260px;margin:0 auto 14px;font-family:var(--ff-mono);}

/* PROGRESS */
.pb{height:4px;background:var(--cream2);border-radius:0;overflow:hidden;}
.pbf{height:100%;border-radius:0;background:var(--ok);transition:width .5s;}

/* SEARCH */
.sw{position:relative;}
.sw::before{content:'>>';position:absolute;left:8px;top:50%;transform:translateY(-50%);font-size:10px;z-index:1;color:var(--muted);font-family:var(--ff-mono);}
.si{padding:7px 10px 7px 28px;border:1.5px solid var(--cream2);border-radius:0;font-family:var(--ff-mono);font-size:12px;background:var(--white);}
.si:focus{outline:none;border-color:var(--navy);}

/* SECTION HEADER */
.sh{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.st{font-family:var(--ff-serif);font-size:16px;letter-spacing:.5px;}

/* ELEVE PANEL */
.epanel{background:var(--white);border-radius:0;border:1.5px solid var(--cream2);overflow:hidden;}
.eitem{padding:10px 14px;cursor:pointer;border-bottom:1px solid var(--cream2);display:flex;align-items:center;justify-content:space-between;transition:background .1s;}
.eitem:last-child{border-bottom:none;}
.eitem:hover{background:#f0ebe0;}
.eitem.on{background:var(--navy);}
.eitem.on .ei-n{color:var(--cream);}
.eitem.on .ei-l{color:rgba(245,240,232,.4);}
.ei-n{font-size:12px;font-family:var(--ff-mono);font-weight:700;}
.ei-l{font-size:10px;color:var(--muted);}

/* TIMETABLE */
.tt-wrap{background:var(--white);border-radius:0;border:1.5px solid #bbb;overflow:hidden;margin-bottom:20px;}
.tt-head{display:flex;border-bottom:2px solid var(--navy);}
.tt-time-col{width:48px;flex-shrink:0;border-right:1px solid var(--cream2);}
.tt-day-hd{flex:1;text-align:center;padding:8px 5px;border-right:1px solid var(--cream2);font-size:10px;font-family:var(--ff-mono);font-weight:700;color:var(--navy);background:var(--cream);letter-spacing:1px;}
.tt-body{display:flex;overflow-x:auto;}
.tt-times{width:48px;flex-shrink:0;border-right:1px solid var(--cream2);}
.tt-hour-lbl{display:flex;align-items:flex-start;justify-content:flex-end;padding:2px 5px 0 0;font-size:9px;color:var(--muted);border-bottom:1px solid var(--cream2);font-family:var(--ff-mono);}
.tt-days{display:flex;flex:1;}
.tt-day-col{flex:1;min-width:86px;position:relative;border-right:1px solid var(--cream2);}
.tt-day-col:last-child{border-right:none;}
.tt-cell{border-bottom:1px solid rgba(0,0,0,.05);}
.tt-event{position:absolute;left:2px;right:2px;border-radius:0;padding:3px 5px;overflow:hidden;cursor:default;z-index:1;border-left:3px solid;}
.tt-ev-ttl{font-size:10px;font-weight:700;line-height:1.3;font-family:var(--ff-mono);}
.tt-ev-sub{font-size:9px;opacity:.8;}
.tt-ev-time{font-size:8px;opacity:.6;margin-top:1px;}

/* APPEL */
.appel-row{display:flex;align-items:center;padding:10px 14px;border-bottom:1px solid var(--cream2);justify-content:space-between;font-family:var(--ff-mono);}
.appel-row:last-child{border-bottom:none;}
.appel-stat-btn{padding:4px 9px;border-radius:0;font-size:10px;font-weight:700;cursor:pointer;font-family:var(--ff-mono);transition:all .1s;border:1.5px solid transparent;}
.appel-footer{padding:8px 14px;background:var(--cream2);display:flex;gap:12px;font-size:11px;font-family:var(--ff-mono);}

/* MBADGE */
.mbadge{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:0;font-size:9px;font-weight:700;font-family:var(--ff-mono);border:1px solid;}
.mb-ok{background:#e8f3e8;color:var(--ok);border-color:var(--ok);}
.mb-full{background:#f3e8e8;color:var(--err);border-color:var(--err);}
.mb-enr{background:#dde6f0;color:var(--info);border-color:var(--info);}

/* FACTURATION */
.fam-card{background:var(--white);border-radius:0;border:1.5px solid var(--cream2);overflow:hidden;transition:all .15s;}
.fam-card:hover{border-color:#aaa;}
.fam-hd{padding:12px 16px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--cream2);cursor:pointer;}
.fam-hd:hover{background:#f0ebe0;}
