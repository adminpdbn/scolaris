function EmploiDuTemps({user,users,cours,setCours,modules,enrollments,dispos=[]}){
  // Filter cours by role
  const myCours = user.role==='eleve'
    ? cours.filter(c=>c.eleveIds.includes(user.id))
    : user.role==='admin'
    ? cours
    : cours.filter(c=>c.profId===user.id);

  const enr=enrollments[user.id]||[];
  const myMods=user.role==='eleve'
    ? modules.filter(m=>enr.includes(m.id))
    : user.role==='admin'
    ? modules
    : modules.filter(m=>m.profId===user.id);

  const byDay=DAYS.reduce((acc,d)=>{acc[d]=myCours.filter(c=>c.jour===d);return acc;},{});

  const Legend=()=><div style={{display:'flex',gap:10,flexWrap:'wrap',marginBottom:14,alignItems:'center'}}>
    {Object.entries(MC).map(([m,c])=>(
      <div key={m} style={{display:'flex',alignItems:'center',gap:5,fontSize:12}}>
        <div style={{width:11,height:11,borderRadius:3,background:c.bg,border:`2px solid ${c.bd}`}}/>
        <span style={{color:'var(--muted)'}}>{m}</span>
      </div>
    ))}
    <div style={{marginLeft:8,paddingLeft:8,borderLeft:'1px solid var(--cream2)',display:'flex',gap:8}}>
      <div style={{display:'flex',alignItems:'center',gap:4,fontSize:12}}><div style={{width:11,height:11,borderRadius:3,background:'#EEFFF6',border:'1.5px dashed #10B981'}}/><span style={{color:'var(--muted)'}}>Dispo libre</span></div>
      <div style={{display:'flex',alignItems:'center',gap:4,fontSize:12}}><div style={{width:11,height:11,borderRadius:3,background:'#FFF8EE',border:'1.5px dashed #D97706'}}/><span style={{color:'var(--muted)'}}>Réservé</span></div>
      <div style={{display:'flex',alignItems:'center',gap:4,fontSize:12}}><div style={{width:11,height:11,borderRadius:3,background:'#EEF5FF',border:'1.5px dashed #1A6FD4'}}/><span style={{color:'var(--muted)'}}>Confirmé</span></div>
    </div>
  </div>;

  const hasData=myCours.length>0||myMods.length>0;

  // ── Week navigation for dispos ──
  const [weekOffset,setWeekOffset]=useState(0);
  const getWeekStart=(offset=0)=>{
    const d=new Date();
    d.setHours(0,0,0,0);
    d.setDate(d.getDate()-d.getDay()+1+offset*7); // Monday
    return d;
  };
  const weekStart=getWeekStart(weekOffset);
  const weekEnd=new Date(weekStart);weekEnd.setDate(weekStart.getDate()+6);
  const weekLabel=`${weekStart.toLocaleDateString('fr-FR',{day:'numeric',month:'short'})} – ${weekEnd.toLocaleDateString('fr-FR',{day:'numeric',month:'short',year:'numeric'})}`;

  // Map DAYS to actual dates in the displayed week
  const dayToDate=(day)=>{
    const idx=['Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi'].indexOf(day);
    const d=new Date(weekStart);
    d.setDate(weekStart.getDate()+idx);
    return d.toISOString().split('T')[0];
  };

  // Dispos visible to this user, filtered to displayed week
  const visibleDispos=dispos.filter(d=>{
    if(d.date<weekStart.toISOString().split('T')[0]||d.date>weekEnd.toISOString().split('T')[0])return false;
    if(user.role==='prof')return d.profId===user.id; // prof sees only own
    if(user.role==='eleve')return d.statut==='libre'||d.eleveId===user.id; // eleve sees libre + their reservations
    return true; // admin sees all
  });
  // Group dispos by day
  const disposByDay=DAYS.reduce((acc,d)=>{
    const date=dayToDate(d);
    acc[d]=visibleDispos.filter(x=>x.date===date);
    return acc;
  },{});
  const hasDispos=visibleDispos.length>0;

  const [edtTab,setEdtTab]=useState('vue');
  return <>
    <TB title="Emploi du Temps"/>
    <div className="pg">
    {user.role==='admin'&&<div className="tabs" style={{marginBottom:18,maxWidth:300}}>
      <button className={`tab ${edtTab==='vue'?'on':''}`} onClick={()=>setEdtTab('vue')}>📅 Visualiser</button>
      <button className={`tab ${edtTab==='edit'?'on':''}`} onClick={()=>setEdtTab('edit')}>⚙️ Modifier</button>
    </div>}
    {(edtTab==='vue'||user.role!=='admin')&&<div>
      {/* Week navigation */}
      <div style={{display:'flex',alignItems:'center',gap:12,marginBottom:16}}>
        <button className="btn btn-sm" style={{background:'#f0f4ff',border:'1.5px solid #c8d8f5',color:'var(--info)',padding:'5px 10px'}} onClick={()=>setWeekOffset(w=>w-1)}>◀</button>
        <div style={{fontWeight:600,fontSize:13,flex:1,textAlign:'center',color:'var(--navy)'}}>{weekLabel}</div>
        <button className="btn btn-sm" style={{background:'#f0f4ff',border:'1.5px solid #c8d8f5',color:'var(--info)',padding:'5px 10px'}} onClick={()=>setWeekOffset(w=>w+1)}>▶</button>
        {weekOffset!==0&&<button className="btn btn-sm" style={{background:'var(--cream2)',border:'none',fontSize:11,color:'var(--muted)',padding:'5px 10px'}} onClick={()=>setWeekOffset(0)}>Aujourd'hui</button>}
      </div>
      {!hasData&&!hasDispos ? (
        <div className="emp"><div className="emp-icon">📅</div><h3>Aucun cours planifié</h3><p>Votre emploi du temps apparaîtra ici.</p></div>
      ) : <>
        <Legend/>
        {/* Weekly grid */}
        <div className="tt-wrap">
          {/* Day headers */}
          <div className="tt-head">
            <div className="tt-time-col" style={{height:44}}/>
            {DAYS.map(d=>{
              const count=byDay[d].length;
              const dateStr=dayToDate(d);
              const isToday=dateStr===new Date().toISOString().split('T')[0];
              const dispoCount=disposByDay[d]?.length||0;
              return <div key={d} className="tt-day-hd" style={{position:'relative',height:44,flexDirection:'column',gap:1,justifyContent:'center'}}>
                <div style={{fontWeight:700,fontSize:11,letterSpacing:.5,color:isToday?'var(--gold)':'var(--navy)'}}>{d.slice(0,3).toUpperCase()}</div>
                <div style={{fontSize:10,color:isToday?'var(--gold)':'var(--muted)'}}>{new Date(dateStr+'T12:00:00').toLocaleDateString('fr-FR',{day:'numeric',month:'short'})}</div>
                {(count>0||dispoCount>0)&&<div style={{position:'absolute',top:6,right:6,display:'flex',gap:2}}>
                  {count>0&&<span style={{width:15,height:15,borderRadius:2,background:'var(--navy)',color:'white',fontSize:8,fontWeight:700,display:'flex',alignItems:'center',justifyContent:'center'}}>{count}</span>}
                  {dispoCount>0&&<span style={{width:15,height:15,borderRadius:2,background:'#10B981',color:'white',fontSize:8,fontWeight:700,display:'flex',alignItems:'center',justifyContent:'center'}}>{dispoCount}</span>}
                </div>}
                {isToday&&<div style={{position:'absolute',bottom:0,left:0,right:0,height:2,background:'var(--gold)',borderRadius:2}}/>}
              </div>;
            })}
          </div>
          {/* Body */}
          <div className="tt-body">
            {/* Time labels */}
            <div className="tt-times">
              {HOURS.map(h=><div key={h} className="tt-hour-lbl" style={{height:CH}}>{h}h</div>)}
            </div>
            {/* Day columns */}
            <div className="tt-days">
              {DAYS.map(d=>(
                <div key={d} className="tt-day-col">
                  {HOURS.map(h=><div key={h} className="tt-cell" style={{height:CH}}/>)}
                  {byDay[d].map(c=>{
                    const clr=mc(c.matiere);
                    const top=(c.debut-H_START)*CH+1;
                    const height=(c.fin-c.debut)*CH-2;
                    const eleveNames=users.filter(u=>c.eleveIds.includes(u.id)).map(u=>u.name.split(' ').slice(-1)[0]);
                    const profName=users.find(u=>u.id===c.profId)?.name.split(' ').slice(-1)[0];
                    return <div key={c.id} className="tt-event" style={{top,height,background:clr.bg,border:`1.5px solid ${clr.bd}`}}>
                      <div className="tt-ev-ttl" style={{color:clr.tx}}>{c.matiere}</div>
                      <div className="tt-ev-sub" style={{color:'var(--text)'}}>{c.niveau}</div>
                      <div className="tt-ev-time" style={{color:'var(--muted)'}}>{hs(c.debut)}–{hs(c.fin)}</div>
                      {height>55&&<div className="tt-ev-time" style={{color:'var(--muted)'}}>{c.salle}{(user.role==='prof'||user.role==='admin')?` · ${c.eleveIds.length} élève${c.eleveIds.length>1?'s':''}`:''}</div>}
                      {user.role==='admin'&&height>75&&<div className="tt-ev-time" style={{color:clr.tx,fontWeight:700,marginTop:1}}>{profName}</div>}
                      {user.role==='prof'&&height>90&&<div className="tt-ev-time" style={{color:'var(--muted)',marginTop:2}}>
                        {eleveNames.join(', ')}
                      </div>}
                    </div>;
                  })}
                  {/* Dispo slots */}
                  {(disposByDay[d]||[]).map(dispo=>{
                    const prof=users.find(u=>u.id===dispo.profId);
                    const top=(dispo.debut-H_START)*CH+1;
                    const height=(dispo.fin-dispo.debut)*CH-2;
                    const isOwn=user.role==='prof'&&dispo.profId===user.id;
                    const isReservedByMe=dispo.eleveId===user.id;
                    const statColor=dispo.statut==='confirme'?'var(--gold)':dispo.statut==='reserve'?'#D97706':'#10B981';
                    const statBg=dispo.statut==='confirme'?'#EEF5FF':dispo.statut==='reserve'?'#FFF8EE':'#EEFFF6';
                    return <div key={dispo.id} style={{
                      position:'absolute',top,height,
                      left:'2px',right:'2px',
                      background:statBg,
                      border:`1.5px dashed ${statColor}`,
                      borderRadius:2,
                      padding:'4px 7px',
                      overflow:'hidden',
                      zIndex:2,
                      cursor:'default'
                    }}>
                      <div style={{fontSize:10,fontWeight:700,color:statColor,lineHeight:1.2,display:'flex',alignItems:'center',gap:3}}>
                        <span>{dispo.mode==='visio'?'💻':dispo.mode==='both'?'🏫💻':'🏫'}</span>
                        <span>Cours particulier</span>
                      </div>
                      {height>28&&<div style={{fontSize:9,color:'var(--muted)',marginTop:1}}>{dispo.matiere}</div>}
                      {height>42&&prof&&!isOwn&&<div style={{fontSize:9,color:'var(--muted)'}}>{prof.name.split(' ').slice(-1)[0]}</div>}
                      {height>42&&<div style={{fontSize:9,color:'var(--muted)'}}>{hs(dispo.debut)}–{hs(dispo.fin)}</div>}
                      {height>56&&<div style={{fontSize:9,color:statColor,fontWeight:600}}>
                        {dispo.statut==='libre'?'Disponible':dispo.statut==='reserve'?isReservedByMe?'✓ Réservé':'En attente':'✓ Confirmé'}
                      </div>}
                    </div>;
                  })}
                </div>
              ))}
            </div>
          </div>
        </div>

        {/* Summary below grid */}
        {(user.role==='prof'||user.role==='admin')&&<>
          <div className="sh" style={{marginBottom:10}}><h2 className="st">{user.role==='admin'?'Tous les cours planifiés':'Récap. de mes cours'}</h2></div>
          <table className="tbl" style={{marginBottom:24}}>
            <thead><tr><th>Cours</th><th>Classe</th>{user.role==='admin'&&<th>Professeur</th>}<th>Créneau</th><th>Salle</th><th>Effectif</th></tr></thead>
            <tbody>{myCours.sort((a,b)=>DAYS.indexOf(a.jour)-DAYS.indexOf(b.jour)||a.debut-b.debut).map(c=>{
              const p=users.find(u=>u.id===c.profId);
              return <tr key={c.id}>
                <td><span style={{...getCoursBadge(c.matiere)}}>{c.matiere}</span></td>
                <td style={{fontWeight:600}}>{c.niveau}</td>
                {user.role==='admin'&&<td style={{fontSize:12}}>{p?.name}</td>}
                <td>{c.jour} · {hs(c.debut)}–{hs(c.fin)}</td>
                <td style={{color:'var(--muted)'}}>{c.salle}</td>
                <td>{c.eleveIds.length} élève{c.eleveIds.length>1?'s':''}</td>
              </tr>;
            })}</tbody>
          </table>
        </>}

        {/* Modules */}
        {myMods.length>0&&<>
          <div className="sh"><h2 className="st">{user.role==='eleve'?'Modules inscrits':'Modules programmés'}</h2></div>
          <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fill,minmax(260px,1fr))',gap:12}}>
            {myMods.map(m=>(
              <div key={m.id} className="res-card" style={{borderLeft:`3px solid ${mc(m.matiere).bd}`}}>
                <div style={{display:'flex',alignItems:'center',gap:10,marginBottom:7}}>
                  <span style={{fontSize:26}}>{m.emoji}</span>
                  <div><div style={{fontWeight:600,fontSize:14}}>{m.title}</div><div style={{fontSize:11,color:'var(--muted)'}}>{m.matiere} · {m.niveau}</div></div>
                </div>
                <div style={{fontSize:12,color:'var(--muted)',lineHeight:1.6}}>
                  <div>📅 {m.date} · {m.heure}</div>
                  <div>📍 {m.lieu}</div>
                </div>
                <div style={{marginTop:8}}><span className="mbadge mb-enr">{user.role==='eleve'?'✓ Inscrit':'📋 Mon module'}</span></div>
              </div>
            ))}
          </div>
        </>}
      </>}
    </div>}
    {user.role==='admin'&&edtTab==='edit'&&<PlanningEditor users={users} cours={cours} setCours={setCours}/>}
    </div>
  </>;
}
function getCoursBadge(matiere){const c=mc(matiere);return{background:c.bg,color:c.tx,padding:'2px 8px',borderRadius:2,fontSize:11,fontWeight:700};}

// ─── DASHBOARD ───
function Dashboard({user,users,resources,modules,grades,enrollments,cours}){
  const eg=grades[user.id]||[];
  const ee=enrollments[user.id]||[];
  const m=moy(eg);
  const eleves=users.filter(u=>u.role==='eleve');
  const profs=users.filter(u=>u.role==='prof');
  const myRes=resources.filter(r=>r.auteurId===user.id);
  const myMod=modules.filter(m=>m.profId===user.id);
  const myCours=cours.filter(c=>c.profId===user.id);

  if(user.role==='eleve'){
    const enrMods=modules.filter(mod=>ee.includes(mod.id));
    const myCoursList=cours.filter(c=>c.eleveIds.includes(user.id));
    const tData={enr:ee,m:m||0,gs:eg,cours:myCoursList.length,totalCours:cours.length,jours:30,absences:0,retards:0,remarques:0,questions:1,devoirs:0,participations:0,mentions:0};
    const earnedIds=new Set(TROPHIES.filter(t=>t.cond(tData)).map(t=>t.id));
    const nbTrophies=earnedIds.size;

    // ── Radar chart data ──
    const radarAxes=[
      {label:'Notes',value:m?Math.round((parseFloat(m)/20)*100):0},
      {label:'Assiduité',value:Math.min(100,Math.round((myCoursList.length/Math.max(cours.length,1))*100))},
      {label:'Modules',value:Math.min(100,enrMods.length*25)},
      {label:'Trophées',value:Math.round((nbTrophies/TROPHIES.length)*100)},
      {label:'Comportement',value:100},
      {label:'Ancienneté',value:40},
    ];
    const cx=160,cy=160,R=120;
    const n=radarAxes.length;
    const pts=radarAxes.map((ax,i)=>{
      const angle=(i/n)*2*Math.PI-Math.PI/2;
      const r=(ax.value/100)*R;
      return {x:cx+r*Math.cos(angle),y:cy+r*Math.sin(angle),lx:cx+(R+28)*Math.cos(angle),ly:cy+(R+28)*Math.sin(angle)};
    });
    const gridPts=(pct)=>radarAxes.map((_,i)=>{
      const angle=(i/n)*2*Math.PI-Math.PI/2;
      return `${cx+pct*R*Math.cos(angle)},${cy+pct*R*Math.sin(angle)}`;
    }).join(' ');
    const dataPath=pts.map((p,i)=>`${i===0?'M':'L'}${p.x},${p.y}`).join(' ')+'Z';

    // Trophy categories for the board
    const trophysCats=[
      {key:'debut',icon:'🎒',label:'Démarrage'},
      {key:'assiduite',icon:'📅',label:'Assiduité'},
      {key:'module',icon:'🎯',label:'Modules'},
      {key:'notes',icon:'📊',label:'Notes'},
      {key:'matiere',icon:'📚',label:'Matières'},
      {key:'progression',icon:'📈',label:'Progression'},
      {key:'comportement',icon:'😇',label:'Comportement'},
      {key:'anciennete',icon:'🌱',label:'Ancienneté'},
      {key:'bonus',icon:'💡',label:'Bonus'},
    ];

    return <div className="fa-in">
      <div style={{padding:'22px 26px 0'}}>
        <div className="wb">
          <h2>Bonjour, <span className="gold">{user.name.split(' ')[0]}</span> 👋</h2>
          <p>{user.niveau} · {myCoursList.length} cours hebdo · {enrMods.length} module{enrMods.length!==1?'s':''}</p>
        </div>
        <div className="sg">
          <div className="sc c-gold"><div className="sc-ic">📊</div><div className="sc-v">{m||'—'}</div><div className="sc-l">Moyenne /20</div></div>
          <div className="sc c-info"><div className="sc-ic">📅</div><div className="sc-v">{myCoursList.length}</div><div className="sc-l">Cours/semaine</div></div>
          <div className="sc c-ok"><div className="sc-ic">🗓️</div><div className="sc-v">{enrMods.length}</div><div className="sc-l">Modules inscrits</div></div>
          <div className="sc c-navy"><div className="sc-ic">🏆</div><div className="sc-v">{nbTrophies}</div><div className="sc-l">Trophées</div></div>
        </div>
      </div>
      <div className="pg" style={{paddingTop:0}}>
        {/* ── RADAR + NOTES ── */}
        <div style={{display:'grid',gridTemplateColumns:'320px 1fr',gap:24,marginBottom:28,alignItems:'start'}}>
          {/* Radar chart */}
          <div style={{background:'white',border:'1.5px solid var(--cream2)',borderRadius:0,padding:'20px',textAlign:'center'}}>
            <div style={{fontFamily:'Cormorant Garamond,serif',fontSize:16,fontWeight:600,marginBottom:14,color:'var(--navy)'}}>Profil de compétences</div>
            <svg viewBox="0 0 320 320" style={{width:'100%',maxWidth:280,margin:'0 auto',display:'block'}}>
              {/* Grid rings */}
              {[0.25,0.5,0.75,1].map(pct=>(
                <polygon key={pct} points={gridPts(pct)} fill="none" stroke={pct===1?'var(--cream2)':'var(--cream2)'} strokeWidth={pct===1?1.5:1} strokeDasharray={pct===1?'none':'4 3'}/>
              ))}
              {/* Axes */}
              {radarAxes.map((_,i)=>{
                const angle=(i/n)*2*Math.PI-Math.PI/2;
                return <line key={i} x1={cx} y1={cy} x2={cx+R*Math.cos(angle)} y2={cy+R*Math.sin(angle)} stroke="var(--cream2)" strokeWidth="1"/>;
              })}
              {/* Data area */}
              <path d={dataPath} fill="rgba(26,111,212,0.12)" stroke="var(--gold)" strokeWidth="2" strokeLinejoin="round"/>
              {/* Data points */}
              {pts.map((p,i)=><circle key={i} cx={p.x} cy={p.y} r="4" fill="var(--gold)" stroke="white" strokeWidth="1.5"/>)}
              {/* Labels */}
              {radarAxes.map((ax,i)=>{
                const p=pts[i];
                const anchor=p.lx<cx-5?'end':p.lx>cx+5?'start':'middle';
                return <text key={i} x={p.lx} y={p.ly} textAnchor={anchor} dominantBaseline="middle" fontSize="11" fontFamily="Space Grotesk,sans-serif" fill="var(--muted)" fontWeight="500">{ax.label}</text>;
              })}
              {/* Center value */}
              {m&&<text x={cx} y={cy} textAnchor="middle" dominantBaseline="middle" fontSize="20" fontFamily="Cormorant Garamond,serif" fontWeight="600" fill="var(--navy)">{m}</text>}
            </svg>
            <div style={{display:'flex',flexWrap:'wrap',gap:6,justifyContent:'center',marginTop:10}}>
              {radarAxes.map((ax,i)=>(
                <div key={i} style={{display:'flex',alignItems:'center',gap:4,fontSize:11,color:'var(--muted)'}}>
                  <div style={{width:8,height:8,borderRadius:2,background:'var(--gold)',opacity:0.3+ax.value/150}}/>
                  <span>{ax.label} {ax.value}%</span>
                </div>
              ))}
            </div>
          </div>
          {/* Notes récentes */}
          <div>
            <div style={{fontFamily:'Cormorant Garamond,serif',fontSize:16,fontWeight:600,marginBottom:12,color:'var(--navy)'}}>Dernières notes</div>
            {eg.length===0?<div style={{color:'var(--muted)',fontSize:13}}>Aucune note enregistrée.</div>:
            <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fill,minmax(140px,1fr))',gap:10}}>
              {eg.map((g,i)=><div key={i} className="nc">
                <div className="nc-sub">{g.matiere}</div>
                <div className="nc-v" style={{color:gcol(g.note,g.max)}}>{g.note}</div>
                <div className="nc-max">/ {g.max}</div>
                <div className="nc-note">{g.commentaire}</div>
              </div>)}
            </div>}
            {myCoursList.length>0&&<>
              <div style={{fontFamily:'Cormorant Garamond,serif',fontSize:16,fontWeight:600,margin:'18px 0 10px',color:'var(--navy)'}}>Mes cours</div>
              <div style={{display:'flex',flexDirection:'column',gap:7}}>
                {myCoursList.map(c=><div key={c.id} style={{display:'flex',alignItems:'center',gap:10,padding:'8px 12px',background:'white',border:'1.5px solid var(--cream2)',borderRadius:0}}>
                  <span style={{...getCoursBadge(c.matiere),flexShrink:0}}>{c.matiere}</span>
                  <div style={{flex:1,minWidth:0}}>
                    <div style={{fontWeight:600,fontSize:13}}>{c.niveau}</div>
                    <div style={{fontSize:11,color:'var(--muted)'}}>{c.jour} · {hs(c.debut)}–{hs(c.fin)} · {c.salle}</div>
                  </div>
                </div>)}
              </div>
            </>}
          </div>
        </div>

        {/* ── TROPHY BOARD ── */}
        <div style={{fontFamily:'Cormorant Garamond,serif',fontSize:18,fontWeight:600,marginBottom:4,color:'var(--navy)'}}>Tableau des réussites</div>
        <div style={{fontSize:12,color:'var(--muted)',marginBottom:18}}>{nbTrophies} trophée{nbTrophies>1?'s':''} obtenu{nbTrophies>1?'s':''} sur {TROPHIES.length}</div>
        {/* Progress bar */}
        <div style={{height:6,background:'var(--cream2)',borderRadius:3,marginBottom:24,overflow:'hidden'}}>
          <div style={{height:'100%',width:`${Math.round((nbTrophies/TROPHIES.length)*100)}%`,background:'var(--ok)',borderRadius:3,transition:'width .8s ease'}}/>
        </div>
        <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fill,minmax(300px,1fr))',gap:16}}>
          {trophysCats.map(cat=>{
            const catTrophies=TROPHIES.filter(t=>t.cat===cat.key);
            const earned=catTrophies.filter(t=>earnedIds.has(t.id));
            return <div key={cat.key} style={{background:'white',border:'1.5px solid var(--cream2)',borderRadius:0,padding:'16px 18px'}}>
              <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:12}}>
