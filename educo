// ─── STATISTIQUES ───
function Statistiques({users,cours,factures,salaires,setSalaires}){
  const [showSal,setShowSal]=useState(false);
  const profs=users.filter(u=>u.role==='prof');
  const eleves=users.filter(u=>u.role==='eleve');
  const TARIF=55;
  const totalBille=factures.reduce((a,f)=>a+f.montant,0);
  const totalPaye=factures.filter(f=>f.statut==='paye').reduce((a,f)=>a+f.montant,0);
  const totalAttente=factures.filter(f=>f.statut==='attente').reduce((a,f)=>a+f.montant,0);
  const totalRetard=factures.filter(f=>f.statut==='retard').reduce((a,f)=>a+f.montant,0);
  const tauxEncaissement=totalBille>0?Math.round((totalPaye/totalBille)*100):0;
  const tauxRetard=totalBille>0?Math.round((totalRetard/totalBille)*100):0;
  const mrrParEleve=eleves.map(e=>{
    const matieres=new Set(cours.filter(c=>c.eleveIds.includes(e.id)).map(c=>c.matiere));
    return{id:e.id,name:e.name,niveau:e.niveau,matieres:[...matieres],mrr:matieres.size*TARIF};
  }).filter(e=>e.mrr>0);
  const mrrTotal=mrrParEleve.reduce((a,e)=>a+e.mrr,0);
  const mrrTrimestriel=mrrTotal*3;
  const salProfs=profs.map(p=>{
    const sal=salaires.find(s=>s.profId===p.id)||{tauxHoraire:35};
    const heures=cours.filter(c=>c.profId===p.id).reduce((a,c)=>a+(c.fin-c.debut),0);
    const salMensuel=Math.round(sal.tauxHoraire*heures*4.33);
    return{...p,tauxHoraire:sal.tauxHoraire,heuresHebdo:heures.toFixed(1),salMensuel};
  });
  const totalSalMensuel=salProfs.reduce((a,p)=>a+p.salMensuel,0);
  const margeMensuelle=mrrTotal-totalSalMensuel;
  const margeRate=mrrTotal>0?Math.round((margeMensuelle/mrrTotal)*100):0;
  const familles=useMemo(()=>{
    const map={};
    eleves.forEach(e=>{
      const ln=e.name.trim().split(/\s+/).slice(-1)[0];
      const id='fam_'+ln.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'');
      if(!map[id])map[id]={id,nom:'Famille '+ln,eleveIds:[e.id]};
      else map[id].eleveIds.push(e.id);
    });
    return Object.values(map);
  },[eleves]);
  const famStats=familles.map(fam=>{
    const ff=factures.filter(f=>f.familleId===fam.id);
    const total=ff.reduce((a,f)=>a+f.montant,0);
    const paye=ff.filter(f=>f.statut==='paye').reduce((a,f)=>a+f.montant,0);
    const retard=ff.filter(f=>f.statut==='retard').reduce((a,f)=>a+f.montant,0);
    const mats=new Set(cours.filter(c=>c.eleveIds.some(eid=>fam.eleveIds.includes(eid))).map(c=>c.matiere));
    return{...fam,total,paye,retard,taux:total>0?Math.round((paye/total)*100):0,mrr:mats.size*TARIF};
  }).filter(f=>f.total>0||f.mrr>0).sort((a,b)=>b.retard-a.retard);
  const MONTHS=['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];
  const byMonth=Array(12).fill(0);
  factures.filter(f=>f.statut==='paye'&&f.datePaiement).forEach(f=>{const m=new Date(f.datePaiement).getMonth();if(m>=0)byMonth[m]+=f.montant;});
  const maxMonth=Math.max(...byMonth,1);
  const last6=MONTHS.slice(6).map((lbl,i)=>({label:lbl,val:byMonth[6+i]}));
  return <>
    <TB title="Statistiques & Budget">
      <button className="btn btn-p btn-sm" onClick={()=>setShowSal(true)}>⚙️ Taux horaires</button>
    </TB>
    <div className="pg">
      <div className="kpi-grid">
        <div className="kpi k-mrr"><div className="kpi-icon">📈</div><div className="kpi-val">{mrrTotal}€</div><div className="kpi-lbl">MRR prévisionnel</div><div className="kpi-sub" style={{color:'var(--gold)'}}>{mrrTrimestriel}€ / trimestre</div></div>
        <div className="kpi k-rev"><div className="kpi-icon">✅</div><div className="kpi-val">{totalPaye}€</div><div className="kpi-lbl">Encaissé</div><div className="kpi-sub" style={{color:'var(--ok)'}}>{tauxEncaissement}% du total facturé</div></div>
        <div className="kpi k-pend"><div className="kpi-icon">⏳</div><div className="kpi-val">{totalAttente}€</div><div className="kpi-lbl">En attente</div><div className="kpi-sub" style={{color:'#D97706'}}>{factures.filter(f=>f.statut==='attente').length} facture{factures.filter(f=>f.statut==='attente').length>1?'s':''}</div></div>
        <div className="kpi k-retard"><div className="kpi-icon">⚠️</div><div className="kpi-val">{totalRetard}€</div><div className="kpi-lbl">En retard</div><div className="kpi-sub" style={{color:'var(--err)'}}>{tauxRetard}% du total</div></div>
        <div className="kpi k-salary"><div className="kpi-icon">👨‍🏫</div><div className="kpi-val">{totalSalMensuel}€</div><div className="kpi-lbl">Masse salariale / mois</div><div className="kpi-sub" style={{color:'var(--navy)'}}>{totalSalMensuel*12}€ / an</div></div>
        <div className="kpi k-margin"><div className="kpi-icon">{margeMensuelle>=0?'💚':'🔴'}</div><div className="kpi-val" style={{color:margeMensuelle>=0?'#7C3AED':'var(--err)'}}>{margeMensuelle>0?'+':''}{margeMensuelle}€</div><div className="kpi-lbl">Marge mensuelle nette</div><div className="kpi-sub" style={{color:margeRate>=0?'#7C3AED':'var(--err)'}}>{margeRate}% de marge</div></div>
      </div>
      <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:20,marginBottom:20}}>
        <div className="stat-section">
          <div className="stat-section-ttl">📊 Revenus encaissés — 6 derniers mois</div>
          <div className="bar-chart">
            {last6.map((m,i)=><div key={i} className="bar-wrap">
              <div className="bar-val" style={{color:'var(--ok)'}}>{m.val>0?m.val+'€':''}</div>
              <div className="bar-col" style={{height:`${Math.round((m.val/maxMonth)*110)}px`,background:m.val>0?'linear-gradient(180deg,#34d399,#2D9B6F)':'var(--cream2)',minHeight:4}}/>
              <div className="bar-lbl">{m.label}</div>
            </div>)}
          </div>
        </div>
        <div className="stat-section">
          <div className="stat-section-ttl">🍩 Répartition des paiements</div>
          {totalBille===0?<div style={{fontSize:13,color:'var(--muted)',textAlign:'center',padding:'30px 0'}}>Aucune facture</div>:(
          <div className="donut-wrap">
            <svg width="110" height="110" viewBox="0 0 36 36">
              {(()=>{
                const segs=[{val:totalPaye,col:'#2D9B6F'},{val:totalAttente,col:'#D97706'},{val:totalRetard,col:'#C94A4A'}].filter(s=>s.val>0);
                const r=15.9155,c=18,circ=2*Math.PI*r;
                let off=25;
                return segs.map((s,i)=>{const pct=s.val/totalBille;const dash=pct*circ;const el=<circle key={i} cx={c} cy={c} r={r} fill="none" stroke={s.col} strokeWidth="3.5" strokeDasharray={`${dash} ${circ-dash}`} strokeDashoffset={-off*circ/100}/>;off-=pct*100;return el;});
              })()}
              <text x="18" y="18" textAnchor="middle" dominantBaseline="middle" style={{fontSize:5,fontWeight:700,fill:'var(--navy)'}}>{tauxEncaissement}%</text>
            </svg>
            <div className="donut-legend">
              {[{label:'Payé',val:totalPaye,col:'#2D9B6F'},{label:'En attente',val:totalAttente,col:'#D97706'},{label:'En retard',val:totalRetard,col:'#C94A4A'}].map(s=><div key={s.label} className="donut-item"><span style={{width:10,height:10,borderRadius:2,background:s.col,display:'inline-block',flexShrink:0}}/><span style={{color:'var(--muted)'}}>{s.label}</span><span style={{marginLeft:'auto',fontWeight:700}}>{s.val}€</span></div>)}
              <div className="donut-item" style={{borderTop:'1px solid var(--cream2)',paddingTop:5,marginTop:2}}><span style={{fontWeight:700}}>Total</span><span style={{marginLeft:'auto',fontWeight:700}}>{totalBille}€</span></div>
            </div>
          </div>)}
        </div>
      </div>
      <div className="stat-section">
        <div className="stat-section-ttl">💶 MRR prévisionnel par élève — {TARIF}€/matière/mois</div>
        {mrrParEleve.length===0?<div style={{fontSize:13,color:'var(--muted)'}}>Aucun élève inscrit dans un cours</div>:(
        <>
          {mrrParEleve.map(e=><div key={e.id} className="prog-row">
            <div className="prog-label"><div style={{fontWeight:600,fontSize:12}}>{e.name}</div><div style={{fontSize:10,color:'var(--muted)'}}>{e.matieres.join(', ')}</div></div>
            <div className="prog-bar"><div className="prog-fill" style={{width:`${(e.mrr/Math.max(...mrrParEleve.map(x=>x.mrr)))*100}%`,background:'var(--gold2)'}}/></div>
            <div className="prog-pct" style={{color:'var(--navy)',fontFamily:'Playfair Display,serif'}}>{e.mrr}€</div>
          </div>)}
          <div style={{borderTop:'1px solid var(--cream2)',marginTop:12,paddingTop:10,display:'flex',justifyContent:'space-between',fontWeight:700,fontSize:13}}>
            <span>Total MRR</span><span style={{color:'var(--gold)',fontFamily:'Playfair Display,serif',fontSize:16}}>{mrrTotal}€/mois</span>
          </div>
        </>)}
      </div>
      <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:20,marginBottom:20}}>
        <div className="stat-section">
          <div className="stat-section-ttl">👨‍🏫 Masse salariale prévisionnelle</div>
          {salProfs.map(p=><div key={p.id} className="prog-row">
            <div className="prog-label"><div style={{fontWeight:600,fontSize:12}}>{p.name.split(' ').slice(-1)[0]}</div><div style={{fontSize:10,color:'var(--muted)'}}>{p.heuresHebdo}h/sem · {p.tauxHoraire}€/h</div></div>
            <div className="prog-bar"><div className="prog-fill" style={{width:`${totalSalMensuel>0?(p.salMensuel/totalSalMensuel)*100:0}%`,background:'var(--navy)'}}/></div>
            <div className="prog-pct" style={{color:'var(--navy)',fontFamily:'Playfair Display,serif'}}>{p.salMensuel}€</div>
          </div>)}
          <div style={{borderTop:'1px solid var(--cream2)',marginTop:10,paddingTop:10,display:'flex',justifyContent:'space-between',fontWeight:700,fontSize:13}}>
            <span>Total mensuel</span><span style={{fontFamily:'Playfair Display,serif',fontSize:16,color:'var(--navy)'}}>{totalSalMensuel}€</span>
          </div>
        </div>
        <div className="stat-section">
          <div className="stat-section-ttl">📋 Synthèse budget mensuel</div>
          {[{label:'Revenus prévisionnels (MRR)',val:mrrTotal,col:'var(--ok)',sign:'+'},{label:'Masse salariale',val:totalSalMensuel,col:'var(--err)',sign:'−'},{label:'Marge nette',val:Math.abs(margeMensuelle),col:margeMensuelle>=0?'#7C3AED':'var(--err)',sign:margeMensuelle>=0?'+':'−'}].map((r,i)=>(
            <div key={i} style={{display:'flex',justifyContent:'space-between',alignItems:'center',padding:'10px 0',borderBottom:i<2?'1px solid var(--cream2)':'none'}}>
              <span style={{fontSize:13,color:i===2?r.col:'var(--text)',fontWeight:i===2?700:400}}>{r.label}</span>
              <span style={{fontFamily:'Playfair Display,serif',fontSize:i===2?20:15,fontWeight:700,color:r.col}}>{r.sign}{r.val}€</span>
            </div>
          ))}
          <div style={{background:margeMensuelle>=0?'#F5EEFF':'#FFF0F0',borderRadius:2,padding:'10px 14px',marginTop:10,textAlign:'center'}}>
            <div style={{fontSize:11,color:'var(--muted)'}}>Taux de marge</div>
            <div style={{fontFamily:'Playfair Display,serif',fontSize:28,fontWeight:700,color:margeMensuelle>=0?'#7C3AED':'var(--err)'}}>{margeRate}%</div>
          </div>
        </div>
      </div>
      <div className="stat-section">
        <div className="stat-section-ttl">👨‍👩‍👧 Taux de paiement par famille</div>
        {famStats.length===0?<div style={{fontSize:13,color:'var(--muted)'}}>Aucune donnée</div>:(
        <table className="tbl">
          <thead><tr><th>Famille</th><th>MRR</th><th>Facturé</th><th>Encaissé</th><th>Retard</th><th>Taux</th></tr></thead>
          <tbody>{famStats.map(f=><tr key={f.id}>
            <td style={{fontWeight:600,fontSize:13}}>{f.nom}</td>
            <td style={{fontSize:12,color:'var(--gold)',fontWeight:700}}>{f.mrr}€</td>
            <td style={{fontSize:12}}>{f.total}€</td>
            <td style={{color:'var(--ok)',fontWeight:600,fontSize:12}}>{f.paye}€</td>
            <td style={{color:f.retard>0?'var(--err)':'var(--muted)',fontWeight:f.retard>0?700:400,fontSize:12}}>{f.retard>0?f.retard+'€':'—'}</td>
            <td><div style={{display:'flex',alignItems:'center',gap:7}}>
              <div style={{flex:1,height:6,background:'var(--cream2)',borderRadius:3,overflow:'hidden',minWidth:50}}><div style={{height:'100%',borderRadius:3,width:`${f.taux}%`,background:f.taux>=80?'var(--ok)':f.taux>=50?'#D97706':'var(--err)',transition:'width .5s'}}/></div>
              <span style={{fontSize:11,fontWeight:700,color:f.taux>=80?'var(--ok)':f.taux>=50?'#D97706':'var(--err)',minWidth:28}}>{f.taux}%</span>
            </div></td>
          </tr>)}</tbody>
        </table>)}
      </div>
    </div>
    {showSal&&<Modal title="Taux horaires des professeurs" onClose={()=>setShowSal(false)}>
      <p style={{fontSize:13,color:'var(--muted)',marginBottom:16}}>Définissez le taux horaire brut. Les heures sont calculées depuis le planning.</p>
      {profs.map(p=>{const s=salaires.find(x=>x.profId===p.id);const heures=cours.filter(c=>c.profId===p.id).reduce((a,c)=>a+(c.fin-c.debut),0);return<div key={p.id} className="fg">
        <label className="fl">{p.name} — {heures.toFixed(1)}h/semaine</label>
        <div style={{display:'flex',gap:8,alignItems:'center'}}>
          <input className="fi" type="number" style={{width:100}} defaultValue={s?.tauxHoraire||35}
            onChange={e=>setSalaires(prev=>{const ex=prev.find(x=>x.profId===p.id);if(ex)return prev.map(x=>x.profId===p.id?{...x,tauxHoraire:parseFloat(e.target.value)}:x);return[...prev,{profId:p.id,tauxHoraire:parseFloat(e.target.value)}];})}/>
          <span style={{fontSize:13,color:'var(--muted)'}}>€/h brut · ~{Math.round((s?.tauxHoraire||35)*heures*4.33)}€/mois</span>
        </div>
      </div>;})}
      <div className="fa"><button className="btn btn-p" onClick={()=>setShowSal(false)}>Fermer</button></div>
    </Modal>}
  </>;
}



// ─── SUIVI COMPÉTENCES ───
function SuiviCompetences({user,users,cours,compEtats,setCompEtats,customComps=[],setCustomComps,awardedTrophies={},setAwardedTrophies}){
  const [selEleve,setSelEleve]=useState(null);
  const [selMat,setSelMat]=useState('Toutes');
  const [showValidModal,setShowValidModal]=useState(false);
  const [validTarget,setValidTarget]=useState(null);
  const [validForm,setValidForm]=useState({statut:'valide',commentaire:''});
  const [showAddComp,setShowAddComp]=useState(false);
  const [addCompForm,setAddCompForm]=useState({eleveId:'',matiere:'Mathématiques',chapitre:'',nom:'',tier:'base'});

  const eleves=users.filter(u=>u.role==='eleve');
  const viewedId=user.role==='eleve'?user.id:selEleve;

  // All templates (base + custom)
  const allTemplates=(eleveId)=>{
    const el=users.find(u=>u.id===eleveId);
    if(!el)return[];
    const myCours=cours.filter(c=>c.eleveIds.includes(eleveId));
    const myMats=new Set(myCours.map(c=>c.matiere));
    const base=COMP_TEMPLATES.filter(t=>myMats.has(t.matiere)&&(t.niveau===el.niveau||!t.niveau));
    const custom=(customComps||[]).filter(t=>t.eleveId===eleveId);
    return [...base,...custom];
  };
  const getEtat=(eid,tid)=>(compEtats[eid]||{})[tid]||{statut:'non_commence',commentaire:'',profId:null,date:null};
  const getMatieres=(eid)=>[...new Set(allTemplates(eid).map(t=>t.matiere))];

  const getStats=(eid)=>{
    const tpls=allTemplates(eid);
    if(!tpls.length)return{total:0,valide:0,en_cours:0,a_revoir:0,pct:0};
    const etats=compEtats[eid]||{};
    const v=tpls.filter(t=>(etats[t.id]?.statut||'nc')==='valide').length;
    const e=tpls.filter(t=>(etats[t.id]?.statut||'nc')==='en_cours').length;
    const r=tpls.filter(t=>(etats[t.id]?.statut||'nc')==='a_revoir').length;
    return{total:tpls.length,valide:v,en_cours:e,a_revoir:r,pct:tpls.length?Math.round((v/tpls.length)*100):0};
  };

  const openValidModal=(eid,tid)=>{
    const cur=getEtat(eid,tid);
    setValidTarget({eid,tid});
    setValidForm({statut:cur.statut==='non_commence'?'valide':cur.statut,commentaire:cur.commentaire||''});
    setShowValidModal(true);
  };
  const doValidate=()=>{
    if(!validTarget)return;
    setCompEtats(p=>({...p,[validTarget.eid]:{...(p[validTarget.eid]||{}),[validTarget.tid]:{statut:validForm.statut,commentaire:validForm.commentaire,profId:user.id,date:new Date().toISOString().split('T')[0]}}}));
    setShowValidModal(false);
  };
  const requestWork=(tid)=>{
    setCompEtats(p=>({...p,[user.id]:{...(p[user.id]||{}),[tid]:{...getEtat(user.id,tid),statut:'en_cours',date:new Date().toISOString().split('T')[0]}}}));
  };
  const addCustomComp=()=>{
    if(!addCompForm.nom.trim()||!addCompForm.chapitre.trim())return;
    const id='cc'+Date.now();
    setCustomComps(p=>[...p,{...addCompForm,id}]);
    setShowAddComp(false);
    setAddCompForm({eleveId:viewedId||'',matiere:'Mathématiques',chapitre:'',nom:'',tier:'base'});
  };
  const deleteCustomComp=(id)=>setCustomComps(p=>p.filter(c=>c.id!==id));

  const StatBadge=({st})=>{
    const s=COMP_STATUTS[st]||COMP_STATUTS.non_commence;
    return <span style={{display:'inline-flex',alignItems:'center',gap:3,padding:'2px 8px',borderRadius:20,fontSize:11,fontWeight:600,background:s.bg,color:s.color,border:`1px solid ${s.color}28`}}>{s.icon} {s.label}</span>;
  };
  const TierPill=({tier})=>{
    const m={base:{l:'Base',c:'#6B7280',bg:'#F3F4F6'},intermediaire:{l:'Intermédiaire',c:'#D97706',bg:'#FFF8EE'},avance:{l:'Avancé',c:'#7C3AED',bg:'#F5F3FF'}}[tier]||{l:'Base',c:'#6B7280',bg:'#F3F4F6'};
    return <span style={{fontSize:10,padding:'1px 6px',borderRadius:0,background:m.bg,color:m.c,fontWeight:600}}>{m.l}</span>;
  };

  const CompView=({eid,canEdit})=>{
    const el=users.find(u=>u.id===eid);
    const mats=getMatieres(eid);
    const visibleMats=selMat==='Toutes'?mats:[selMat].filter(m=>mats.includes(m));
    const stats=getStats(eid);

    // Group by matière > chapitre
    const grouped={};
    allTemplates(eid).forEach(t=>{
      if(selMat!=='Toutes'&&t.matiere!==selMat)return;
      if(!grouped[t.matiere])grouped[t.matiere]={};
      if(!grouped[t.matiere][t.chapitre])grouped[t.matiere][t.chapitre]=[];
      grouped[t.matiere][t.chapitre].push({...t,etat:getEtat(eid,t.id),isCustom:!!(customComps||[]).find(c=>c.id===t.id)});
    });

    return <div>
      {/* Programme header */}
      {el&&<div style={{display:'flex',alignItems:'center',gap:10,marginBottom:16}}>
        <div style={{width:42,height:42,borderRadius:0,background:'var(--navy)',display:'flex',alignItems:'center',justifyContent:'center',fontSize:18}}>🎓</div>
        <div>
          <div style={{fontFamily:'Cormorant Garamond,serif',fontSize:18,fontWeight:600,color:'var(--navy)'}}>{el.name}</div>
          <div style={{display:'flex',gap:5,marginTop:4,flexWrap:'wrap'}}>
            <span style={{fontSize:11,padding:'1px 7px',borderRadius:0,background:'var(--cream2)',color:'var(--muted)',fontWeight:500}}>{el.niveau}</span>
            {getMatieres(eid).map(m=><span key={m} style={{...getCoursBadge(m),fontSize:10}}>{m}</span>)}
          </div>
        </div>
        {canEdit&&<button className="btn btn-p btn-sm" style={{marginLeft:'auto'}} onClick={()=>{setAddCompForm(f=>({...f,eleveId:eid}));setShowAddComp(true);}}>＋ Compétence</button>}
      </div>}

      {/* Stats + global bar */}
      <div className="sg" style={{marginBottom:16}}>
        <div className="sc c-ok"><div className="sc-v">{stats.valide}</div><div className="sc-l">Validées</div></div>
        <div className="sc c-gold"><div className="sc-v">{stats.en_cours}</div><div className="sc-l">En cours</div></div>
        <div className="sc" style={{borderColor:'#fecaca'}}><div className="sc-v" style={{color:'var(--err)'}}>{stats.a_revoir}</div><div className="sc-l">À revoir</div></div>
        <div className="sc c-navy"><div className="sc-v">{stats.pct}%</div><div className="sc-l">Progression</div></div>
      </div>
      <div style={{height:8,background:'var(--cream2)',borderRadius:4,overflow:'hidden',marginBottom:20}}>
        <div style={{height:'100%',width:`${stats.pct}%`,background:stats.pct===100?'var(--ok)':'linear-gradient(90deg,#1A6FD4,#4A90E2)',borderRadius:4,transition:'width .6s'}}/>
      </div>

      {/* Matière filter */}
      <div className="tabs" style={{marginBottom:18,flexWrap:'wrap'}}>
        {['Toutes',...mats].map(m=><button key={m} className={`tab ${selMat===m?'on':''}`} onClick={()=>setSelMat(m)} style={{fontSize:11}}>{m}</button>)}
      </div>

      {/* Matières > Chapitres > Compétences */}
      {Object.entries(grouped).map(([mat,chaps])=>(
        <div key={mat} style={{marginBottom:20}}>
          <div style={{display:'flex',alignItems:'center',gap:8,marginBottom:10}}>
            <span style={{...getCoursBadge(mat)}}>{mat}</span>
            {(()=>{const all=Object.values(chaps).flat();const v=all.filter(c=>c.etat.statut==='valide').length;return<span style={{fontSize:12,color:'var(--muted)'}}>{v}/{all.length}</span>})()}
          </div>
          {Object.entries(chaps).map(([chap,comps])=>{
            const chapV=comps.filter(c=>c.etat.statut==='valide').length;
            const chapPct=Math.round((chapV/comps.length)*100);
            return <div key={chap} style={{background:'white',border:'1.5px solid var(--cream2)',borderRadius:0,marginBottom:8,overflow:'hidden'}}>
              <div style={{padding:'10px 16px',background:chapPct===100?'#ECFDF5':'var(--cream)',display:'flex',alignItems:'center',gap:12,borderBottom:'1px solid var(--cream2)'}}>
                <div style={{flex:1}}>
                  <div style={{fontWeight:700,fontSize:13,color:'var(--navy)'}}>{chap}</div>
                  <div style={{fontSize:11,color:'var(--muted)',marginTop:1}}>{chapV}/{comps.length} validée{chapV>1?'s':''}</div>
                </div>
                <div style={{width:72}}>
                  <div style={{height:5,background:'var(--cream2)',borderRadius:3,overflow:'hidden'}}>
                    <div style={{height:'100%',width:`${chapPct}%`,background:chapPct===100?'var(--ok)':'var(--gold)',borderRadius:3}}/>
                  </div>
                  <div style={{fontSize:10,textAlign:'right',color:'var(--muted)',marginTop:2}}>{chapPct}%</div>
                </div>
                {chapPct===100&&<span style={{fontSize:16}}>🏆</span>}
              </div>
              {comps.map(c=>{
                const prof=users.find(u=>u.id===c.etat.profId);
                const st=COMP_STATUTS[c.etat.statut]||COMP_STATUTS.non_commence;
                return <div key={c.id} style={{display:'flex',alignItems:'center',gap:10,padding:'9px 16px',borderBottom:'1px solid rgba(0,0,0,.035)'}}>
                  <div style={{width:24,height:24,borderRadius:2,background:st.bg,border:`2px solid ${st.color}50`,display:'flex',alignItems:'center',justifyContent:'center',fontSize:11,fontWeight:700,color:st.color,flexShrink:0}}>{st.icon}</div>
                  <div style={{flex:1,minWidth:0}}>
                    <div style={{display:'flex',alignItems:'center',gap:5,flexWrap:'wrap'}}>
                      <span style={{fontSize:13,fontWeight:500}}>{c.nom}</span>
                      <TierPill tier={c.tier}/>
                      {c.isCustom&&<span style={{fontSize:10,padding:'1px 5px',background:'#EEF5FF',color:'var(--gold)',borderRadius:2,fontWeight:600}}>Custom</span>}
                    </div>
                    {c.etat.commentaire&&<div style={{fontSize:11,color:'var(--muted)',marginTop:2,fontStyle:'italic'}}>💬 {c.etat.commentaire}</div>}
                    {c.etat.profId&&<div style={{fontSize:10,color:'var(--muted)',marginTop:1}}>par {prof?.name.split(' ').slice(-1)[0]} · {c.etat.date}</div>}
                  </div>
                  <div style={{display:'flex',gap:5,flexShrink:0}}>
                    {canEdit&&(
                      <button className="btn btn-sm" style={{fontSize:11,padding:'3px 9px',background:'#EEF5FF',border:'1.5px solid #C8D8F5',color:'var(--gold)'}}
                        onClick={()=>openValidModal(eid,c.id)}>
                        {c.etat.statut==='non_commence'?'Évaluer':'✏️'}
                      </button>
                    )}
                    {canEdit&&c.isCustom&&(
                      <button className="btn btn-d btn-sm" style={{fontSize:10,padding:'3px 7px'}} onClick={()=>deleteCustomComp(c.id)}>🗑️</button>
                    )}
                    {user.role==='eleve'&&c.etat.statut==='non_commence'&&(
                      <button className="btn btn-sm" style={{fontSize:11,padding:'3px 9px',background:'#FFF8EE',border:'1.5px solid #F0C080',color:'#D97706'}}
                        onClick={()=>requestWork(c.id)}>Je travaille ça</button>
                    )}
                  </div>
                </div>;
              })}
            </div>;
          })}
        </div>
      ))}
      {Object.keys(grouped).length===0&&<div className="emp"><div className="emp-icon">📋</div><h3>Aucune compétence</h3><p>Inscrivez l'élève à des cours pour voir ses compétences.</p></div>}
    </div>;
  };

  return <>
    <TB title="Suivi Compétences">
      {(user.role==='prof'||user.role==='admin')&&viewedId&&<button className="btn btn-p btn-sm" onClick={()=>{setAddCompForm(f=>({...f,eleveId:viewedId}));setShowAddComp(true);}}>＋ Compétence</button>}
    </TB>
    <div className="pg">
      {user.role==='eleve'&&<CompView eid={user.id} canEdit={false}/>}
      {(user.role==='prof'||user.role==='admin')&&<div style={{display:'grid',gridTemplateColumns:'220px 1fr',gap:20,alignItems:'start'}}>
        {/* Sidebar élèves */}
        <div>
          <div style={{fontWeight:700,fontSize:11,color:'var(--muted)',textTransform:'uppercase',letterSpacing:.5,marginBottom:10,paddingLeft:4}}>Élèves</div>
          {eleves.map(e=>{
            const s=getStats(e.id);
            const isMe=user.role==='prof'&&cours.some(c=>c.profId===user.id&&c.eleveIds.includes(e.id));
            if(user.role==='prof'&&!isMe)return null;
            return <div key={e.id} onClick={()=>{setSelEleve(e.id);setSelMat('Toutes');}}
              style={{padding:'10px 12px',borderRadius:0,background:selEleve===e.id?'var(--navy)':'white',border:'1.5px solid var(--cream2)',marginBottom:6,cursor:'pointer'}}>
              <div style={{display:'flex',justifyContent:'space-between',alignItems:'center'}}>
                <div style={{fontWeight:600,fontSize:13,color:selEleve===e.id?'white':'var(--navy)'}}>{e.name}</div>
                <span style={{fontSize:12,fontWeight:700,color:selEleve===e.id?'white':s.pct===100?'var(--ok)':'var(--gold)'}}>{s.pct}%</span>
              </div>
              <div style={{fontSize:11,color:selEleve===e.id?'rgba(255,255,255,.5)':'var(--muted)',marginBottom:6}}>{e.niveau} · {s.valide}/{s.total}</div>
              <div style={{height:3,background:selEleve===e.id?'rgba(255,255,255,.15)':'var(--cream2)',borderRadius:2,overflow:'hidden'}}>
                <div style={{height:'100%',width:`${s.pct}%`,background:s.pct===100?'var(--ok)':'#8b6b3a',borderRadius:2}}/>
              </div>
            </div>;
          })}
        </div>
        <div>
          {!viewedId?<div className="emp"><div className="emp-icon">👆</div><h3>Sélectionnez un élève</h3></div>:<CompView eid={viewedId} canEdit={true}/>}
        </div>
      </div>}
    </div>

    {/* Validation modal */}
    {showValidModal&&validTarget&&(()=>{
      const tpl=[...COMP_TEMPLATES,...(customComps||[])].find(t=>t.id===validTarget.tid);
      const el=users.find(u=>u.id===validTarget.eid);
      return <Modal title="Évaluer la compétence" onClose={()=>setShowValidModal(false)}>
        <div style={{background:'var(--cream)',borderRadius:2,padding:'10px 14px',marginBottom:14}}>
          <div style={{fontWeight:700,fontSize:13}}>{tpl?.nom}</div>
          <div style={{fontSize:12,color:'var(--muted)',marginTop:3}}>{tpl?.chapitre} · {tpl?.matiere}{el?` · ${el.name}`:''}</div>
        </div>
        <div className="fg"><label className="fl">Statut</label>
          <div style={{display:'grid',gridTemplateColumns:'1fr 1fr 1fr',gap:8}}>
            {Object.entries(COMP_STATUTS).filter(([k])=>k!=='non_commence').map(([k,v])=>(
              <div key={k} onClick={()=>setValidForm(f=>({...f,statut:k}))}
                style={{padding:'10px 8px',textAlign:'center',borderRadius:0,border:`2px solid ${validForm.statut===k?v.color:'var(--cream2)'}`,background:validForm.statut===k?v.bg:'white',cursor:'pointer'}}>
                <div style={{fontSize:18}}>{v.icon}</div>
                <div style={{fontSize:11,fontWeight:700,color:v.color,marginTop:4}}>{v.label}</div>
              </div>
            ))}
          </div>
        </div>
        <div className="fg"><label className="fl">Commentaire</label>
          <textarea className="fi" rows={2} value={validForm.commentaire} onChange={e=>setValidForm(f=>({...f,commentaire:e.target.value}))} placeholder="Remarque optionnelle…"/>
        </div>
        <div className="fa"><button className="btn btn-o" onClick={()=>setShowValidModal(false)}>Annuler</button><button className="btn btn-p" onClick={doValidate}>Enregistrer</button></div>
      </Modal>;
    })()}

    {/* Ajout compétence custom */}
    {showAddComp&&<Modal title="Ajouter une compétence" onClose={()=>setShowAddComp(false)}>
      <div className="fg"><label className="fl">Élève</label>
        <select className="fi" value={addCompForm.eleveId} onChange={e=>setAddCompForm(f=>({...f,eleveId:e.target.value}))}>
          <option value="">— Sélectionner —</option>
          {eleves.map(e=><option key={e.id} value={e.id}>{e.name} ({e.niveau})</option>)}
        </select>
      </div>
      <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:10}}>
        <div className="fg"><label className="fl">Matière</label>
          <select className="fi" value={addCompForm.matiere} onChange={e=>setAddCompForm(f=>({...f,matiere:e.target.value}))}>
            {MATIERES.filter(m=>m!=='Toutes').map(m=><option key={m}>{m}</option>)}
          </select>
        </div>
        <div className="fg"><label className="fl">Niveau</label>
          <select className="fi" value={addCompForm.tier} onChange={e=>setAddCompForm(f=>({...f,tier:e.target.value}))}>
            <option value="base">Base</option>
            <option value="intermediaire">Intermédiaire</option>
            <option value="avance">Avancé</option>
          </select>
        </div>
      </div>
      <div className="fg"><label className="fl">Chapitre</label>
        <input className="fi" value={addCompForm.chapitre} onChange={e=>setAddCompForm(f=>({...f,chapitre:e.target.value}))} placeholder="Ex: Nombres et calculs"/>
      </div>
      <div className="fg"><label className="fl">Intitulé de la compétence *</label>
        <input className="fi" value={addCompForm.nom} onChange={e=>setAddCompForm(f=>({...f,nom:e.target.value}))} placeholder="Ex: Résoudre une équation du 2nd degré"/>
      </div>
      <div className="fa"><button className="btn btn-o" onClick={()=>setShowAddComp(false)}>Annuler</button><button className="btn btn-p" onClick={addCustomComp}>Ajouter</button></div>
    </Modal>}
  </>;
}


function CoursParticuliers({user,users,dispos,setDispos,demandes,setDemandes}){
  const [tab,setTab]=useState('planning');
  const [showDispo,setShowDispo]=useState(false);
  const [showDemande,setShowDemande]=useState(false);
  const [dispoForm,setDispoForm]=useState({date:'',debut:'14',fin:'15.5',mode:'presentiel',matiere:'Mathématiques',notes:''});
  const [demandeForm,setDemandeForm]=useState({matiere:'Mathématiques',niveau:'3ème',datePreference:'',creneauDebut:'',creneauFin:'',notes:''});

  const profs=users.filter(u=>u.role==='prof');
  const eleves=users.filter(u=>u.role==='eleve');

  // ── Week navigation ──
  const [weekOffset,setWeekOffset]=useState(0);
  const getWeekStart=(off=0)=>{const d=new Date();d.setHours(0,0,0,0);d.setDate(d.getDate()-d.getDay()+1+off*7);return d;};
  const weekStart=getWeekStart(weekOffset);
  const weekEnd=new Date(weekStart);weekEnd.setDate(weekStart.getDate()+6);
  const weekLabel=`${weekStart.toLocaleDateString('fr-FR',{day:'numeric',month:'short'})} – ${weekEnd.toLocaleDateString('fr-FR',{day:'numeric',month:'short',year:'numeric'})}`;
  const dayToDate2=(day)=>{const idx=['Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi'].indexOf(day);const d=new Date(weekStart);d.setDate(weekStart.getDate()+idx);return d.toISOString().split('T')[0];};
  const CP_H_START=8,CP_H_END=21,CP_CH=48;
  const CP_HOURS=Array.from({length:CP_H_END-CP_H_START},(_,i)=>i+CP_H_START);
  // Filter dispos for this week
  const weekDispos=dispos.filter(d=>{
    const ws=weekStart.toISOString().split('T')[0];
    const we=weekEnd.toISOString().split('T')[0];
    return d.date>=ws&&d.date<=we;
  });
  const visibleWeekDispos=weekDispos.filter(d=>{
    if(user.role==='prof')return d.profId===user.id;
    if(user.role==='eleve')return d.statut==='libre'||d.eleveId===user.id;
    return true;
  });
  const disposByDay2=DAYS.reduce((acc,d)=>{acc[d]=visibleWeekDispos.filter(x=>x.date===dayToDate2(d));return acc;},{});

  // ── Prof actions ──
  const addDispo=()=>{
    if(!dispoForm.date||!dispoForm.debut||!dispoForm.fin)return;
    setDispos(p=>[...p,{id:'d'+Date.now(),profId:user.id,date:dispoForm.date,debut:parseFloat(dispoForm.debut),fin:parseFloat(dispoForm.fin),mode:dispoForm.mode,matiere:dispoForm.matiere,notes:dispoForm.notes,statut:'libre',eleveId:null,demandeId:null}]);
    setShowDispo(false);
    setDispoForm({date:'',debut:'14',fin:'15.5',mode:'presentiel',matiere:'Mathématiques',notes:''});
  };
  const acceptDemande=(dem)=>{
    // Prof accepte une demande → crée une dispo confirmée liée
    const newId='d'+Date.now();
    setDispos(p=>[...p,{id:newId,profId:user.id,date:dem.datePreference,debut:parseFloat(dem.creneauDebut||'14'),fin:parseFloat(dem.creneauFin||'15.5'),mode:'presentiel',matiere:dem.matiere,statut:'confirme',eleveId:dem.eleveId,demandeId:dem.id,notes:dem.notes||''}]);
    setDemandes(p=>p.map(d=>d.id===dem.id?{...d,statut:'acceptee',profId:user.id,disponibiliteId:newId}:d));
  };
  const refuseDemande=(id)=>setDemandes(p=>p.map(d=>d.id===id?{...d,statut:'refusee'}:d));
  const deleteDispo=(id)=>{
    const d=dispos.find(x=>x.id===id);
    if(d?.statut==='confirme'){alert('Impossible de supprimer un créneau confirmé.');return;}
    setDispos(p=>p.filter(x=>x.id!==id));
  };

  // ── Eleve actions ──
  const addDemande=()=>{
    if(!demandeForm.matiere||!demandeForm.datePreference)return;
    setDemandes(p=>[...p,{id:'dem'+Date.now(),eleveId:user.id,matiere:demandeForm.matiere,niveau:demandeForm.niveau,datePreference:demandeForm.datePreference,creneauDebut:demandeForm.creneauDebut,creneauFin:demandeForm.creneauFin,notes:demandeForm.notes,statut:'attente',profId:null,disponibiliteId:null}]);
    setShowDemande(false);
    setDemandeForm({matiere:'Mathématiques',niveau:'3ème',datePreference:'',creneauDebut:'',creneauFin:'',notes:''});
  };
  const reserverDispo=(dispo)=>{
    setDispos(p=>p.map(d=>d.id===dispo.id?{...d,statut:'reserve',eleveId:user.id}:d));
  };
  const annulerReservation=(dispo)=>{
    if(!window.confirm('Annuler cette réservation ?'))return;
    setDispos(p=>p.map(d=>d.id===dispo.id?{...d,statut:'libre',eleveId:null}:d));
  };
  const cancelDemande=(id)=>setDemandes(p=>p.filter(d=>d.id!==id));

  // ── Computed ──
  const myDispos=user.role==='prof'?dispos.filter(d=>d.profId===user.id):dispos;
  const pendingDemandes=demandes.filter(d=>d.statut==='attente');
  const myDemandes=user.role==='eleve'?demandes.filter(d=>d.eleveId===user.id):demandes;
  const libresDispos=dispos.filter(d=>d.statut==='libre'&&d.profId!==user.id);

  const StatusBadge=({s,mode})=>{
    const map={libre:{bg:'#EEFFF6',color:'#2D9B6F',label:'Disponible'},reserve:{bg:'#FFF3E0',color:'#D97706',label:'Réservé'},confirme:{bg:'#EEF5FF',color:'var(--gold)',label:'Confirmé'},attente:{bg:'#FFF8EE',color:'#D97706',label:'En attente'},acceptee:{bg:'#EEFFF6',color:'#2D9B6F',label:'Acceptée'},refusee:{bg:'#FFF0F0',color:'#C94A4A',label:'Refusée'}};
    const m=map[s]||map['attente'];
    return <span style={{...m,padding:'2px 8px',borderRadius:20,fontSize:11,fontWeight:600,display:'inline-flex',alignItems:'center',gap:4}}>
      {s==='libre'?'✓':s==='confirme'?'🎉':s==='reserve'?'⏳':s==='acceptee'?'✅':s==='refusee'?'✗':'⏳'} {m.label}
      {mode&&<span style={{marginLeft:4,opacity:.7}}>{mode==='presentiel'?'🏫':'💻'}</span>}
    </span>;
  };

  const DispoCard=({d,showActions=true})=>{
    const prof=users.find(u=>u.id===d.profId);
    const eleve=users.find(u=>u.id===d.eleveId);
    const clr=mc(d.matiere);
    return <div style={{background:'white',border:'1.5px solid var(--cream2)',borderRadius:0,padding:'16px 20px',marginBottom:10,position:'relative',borderLeft:`4px solid ${clr.bd}`}}>
      <div style={{display:'flex',alignItems:'flex-start',justifyContent:'space-between',gap:12}}>
        <div>
          <div style={{display:'flex',alignItems:'center',gap:8,marginBottom:6}}>
            <span style={{...getCoursBadge(d.matiere),fontSize:12}}>{d.matiere}</span>
            <StatusBadge s={d.statut} mode={d.mode}/>
          </div>
          <div style={{fontWeight:600,fontSize:14,marginBottom:3}}>
            {new Date(d.date).toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long'})}
            {' '}{hs(d.debut)}–{hs(d.fin)}
          </div>
          {prof&&user.role!=='prof'&&<div style={{fontSize:12,color:'var(--muted)',marginBottom:2}}>👨‍🏫 {prof.name}</div>}
          {eleve&&<div style={{fontSize:12,color:'var(--muted)',marginBottom:2}}>🎓 {eleve.name}</div>}
          {d.notes&&<div style={{fontSize:12,color:'var(--muted)',fontStyle:'italic',marginTop:4}}>"{d.notes}"</div>}
        </div>
        {showActions&&<div style={{display:'flex',gap:6,flexShrink:0,flexDirection:'column',alignItems:'flex-end'}}>
          {/* Eleve : réserver un libre */}
          {user.role==='eleve'&&d.statut==='libre'&&d.profId!==user.id&&(
            <button className="btn btn-p btn-sm" onClick={()=>reserverDispo(d)}>Réserver</button>
          )}
          {/* Eleve : annuler sa réservation */}
          {user.role==='eleve'&&d.statut==='reserve'&&d.eleveId===user.id&&(
            <button className="btn btn-d btn-sm" onClick={()=>annulerReservation(d)}>Annuler</button>
          )}
          {/* Prof : supprimer sa dispo */}
          {user.role==='prof'&&d.profId===user.id&&d.statut!=='confirme'&&(
            <button className="btn btn-d btn-sm" onClick={()=>deleteDispo(d.id)}>🗑️</button>
          )}
          {/* Admin */}
          {user.role==='admin'&&<button className="btn btn-d btn-sm" onClick={()=>setDispos(p=>p.filter(x=>x.id!==d.id))}>🗑️</button>}
        </div>}
      </div>
    </div>;
  };

  const DemandeCard=({d,showActions=true})=>{
    const eleve=users.find(u=>u.id===d.eleveId);
    const prof=users.find(u=>u.id===d.profId);
    const clr=mc(d.matiere);
    return <div style={{background:'white',border:'1.5px solid var(--cream2)',borderRadius:0,padding:'16px 20px',marginBottom:10,borderLeft:`4px solid ${clr.bd}`}}>
      <div style={{display:'flex',alignItems:'flex-start',justifyContent:'space-between',gap:12}}>
        <div>
          <div style={{display:'flex',alignItems:'center',gap:8,marginBottom:6}}>
            <span style={{...getCoursBadge(d.matiere),fontSize:12}}>{d.matiere}</span>
            <span style={{background:'#F3F4F8',color:'var(--muted)',padding:'2px 8px',borderRadius:20,fontSize:11,fontWeight:600}}>{d.niveau}</span>
            <StatusBadge s={d.statut}/>
          </div>
          <div style={{fontWeight:600,fontSize:14,marginBottom:3}}>
            Souhait : {d.datePreference?new Date(d.datePreference).toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long'}):'Date flexible'}
            {d.creneauDebut&&d.creneauFin&&<span style={{color:'var(--muted)',fontWeight:400}}> · {hs(parseFloat(d.creneauDebut))}–{hs(parseFloat(d.creneauFin))}</span>}
          </div>
          {eleve&&user.role!=='eleve'&&<div style={{fontSize:12,color:'var(--muted)',marginBottom:2}}>🎓 {eleve.name}</div>}
          {prof&&<div style={{fontSize:12,color:'var(--ok)',marginBottom:2}}>✅ Acceptée par {prof.name}</div>}
          {d.notes&&<div style={{fontSize:12,color:'var(--muted)',fontStyle:'italic',marginTop:4}}>"{d.notes}"</div>}
        </div>
        {showActions&&<div style={{display:'flex',gap:6,flexShrink:0,flexDirection:'column',alignItems:'flex-end'}}>
          {user.role==='prof'&&d.statut==='attente'&&<>
            <button className="btn btn-p btn-sm" onClick={()=>acceptDemande(d)}>✓ Accepter</button>
            <button className="btn btn-d btn-sm" onClick={()=>refuseDemande(d.id)}>✗ Refuser</button>
          </>}
          {user.role==='eleve'&&d.eleveId===user.id&&d.statut==='attente'&&(
            <button className="btn btn-d btn-sm" onClick={()=>cancelDemande(d.id)}>Annuler</button>
          )}
          {user.role==='admin'&&<button className="btn btn-d btn-sm" onClick={()=>setDemandes(p=>p.filter(x=>x.id!==d.id))}>🗑️</button>}
        </div>}
      </div>
    </div>;
  };

  // Build tabs by role
  const tabs=[];
  tabs.push({id:'planning',label:'🗓️ Planning'});
  if(user.role==='prof'){
    tabs.push({id:'mesdispos',label:'📋 Mes disponibilités'});
    tabs.push({id:'demandes',label:`📬 Demandes${pendingDemandes.length>0?` (${pendingDemandes.length})`:''}`});
  }
  if(user.role==='eleve'){
    tabs.push({id:'trouver',label:'🔍 Créneaux libres'});
    tabs.push({id:'mesdemandes',label:'📋 Mes demandes'});
  }
  if(user.role==='admin'){
    tabs.push({id:'suivi',label:'📊 Suivi'});
    tabs.push({id:'demandes',label:`📬 Demandes (${pendingDemandes.length})`});
  }

  return <>
    <TB title="Cours particuliers">
      {user.role==='prof'&&<button className="btn btn-p btn-sm" onClick={()=>setShowDispo(true)}>＋ Ajouter une dispo</button>}
      {user.role==='eleve'&&<button className="btn btn-p btn-sm" onClick={()=>setShowDemande(true)}>＋ Faire une demande</button>}
    </TB>
    <div className="pg">
      <div className="tabs" style={{marginBottom:20}}>
        {tabs.map(t=><button key={t.id} className={`tab ${tab===t.id?'on':''}`} onClick={()=>setTab(t.id)}>{t.label}</button>)}
      </div>

      {/* ── PLANNING TAB ── */}
      {tab==='planning'&&<>
        {/* Week nav */}
        <div style={{display:'flex',alignItems:'center',gap:10,marginBottom:16}}>
          <button className="btn btn-sm" style={{background:'#f0f4ff',border:'1.5px solid #c8d8f5',color:'var(--info)',padding:'5px 12px'}} onClick={()=>setWeekOffset(w=>w-1)}>◀</button>
          <div style={{fontWeight:600,fontSize:13,flex:1,textAlign:'center',color:'var(--navy)'}}>{weekLabel}</div>
          <button className="btn btn-sm" style={{background:'#f0f4ff',border:'1.5px solid #c8d8f5',color:'var(--info)',padding:'5px 12px'}} onClick={()=>setWeekOffset(w=>w+1)}>▶</button>
          {weekOffset!==0&&<button className="btn btn-sm" style={{background:'var(--cream2)',border:'none',fontSize:11,color:'var(--muted)',padding:'5px 10px'}} onClick={()=>setWeekOffset(0)}>Aujourd'hui</button>}
